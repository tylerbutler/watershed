		{
			"action": "processAll"
		},
		{
			"action": "delete",
			"client": "A",
			"key": "x"
		},
		{
			"action": "processAll"
		},
		{
			"action": "check"
		}
	],
	"observations": [
		{
			"afterStep": 4,
			"converged": true,
			"clients": {
				"A": {
					"entries": [],
					"events": [
						{
							"event": "valueChanged",
							"key": "x",
							"local": true
						},
						{
							"event": "valueChanged",
							"key": "x",
							"local": true,
							"previousValue": 1
						}
					]
				},
				"B": {
					"entries": [],
					"events": [
						{
							"event": "valueChanged",
							"key": "x",
							"local": false
						},
						{
							"event": "valueChanged",
							"key": "x",
							"local": false,
							"previousValue": 1
						}
					]
				}
			}
		}
	]
