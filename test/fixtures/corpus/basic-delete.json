{
	"formatVersion": 1,
	"name": "basic-delete",
	"description": "Set then delete a key after sequencing.",
	"clients": [
		"A",
		"B"
	],
	"steps": [
		{
			"action": "set",
			"client": "A",
			"key": "x",
			"value": 1
