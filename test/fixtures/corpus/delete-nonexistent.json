			"action": "processAll"
		},
		{
			"action": "check"
		}
	],
	"observations": [
		{
			"afterStep": 2,
			"converged": true,
			"clients": {
				"A": {
					"entries": [],
					"events": []
				},
				"B": {
					"entries": [],
					"events": [
						{
							"event": "valueChanged",
							"key": "ghost",
							"local": false
						}
					]
				}
			}
		}
	]
