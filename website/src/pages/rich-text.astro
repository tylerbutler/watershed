---
import Sheet from "../layouts/Sheet.astro";
import RichTextDemo from "../components/RichTextDemo.astro";
import Ecosystem from "../components/Ecosystem.astro";
---

<Sheet
  title="watershed — SharedRichText Quill demo"
  description="Three browser Quill editors edit one shared rich-text document through watershed's real rich_text_kernel: optimistic local edits, single-op-in-flight client transform over quill-delta's retain/insert/delete/attribute/embed algebra, UTF-16 code-unit positions, and transformed peer cursors, all converging over the in-memory sluice."
>
  <header class="page-hero">
    <div class="page-hero-inner">
      <p class="eyebrow annot">
        <a href="/">← watershed</a> · SharedRichText operational transform
      </p>
      <h1>Three editors.<br />One document. <em>No merge conflicts.</em></h1>
      <p class="lede">
        <code>json_ot</code> transforms a shared JSON document; this is the
        same protocol turned on rich text. watershed's
        <code>rich_text_kernel</code> ports the quill-delta algebra —
        retain/insert/delete spans, attribute patches, embeds — behind the
        identical single-op-in-flight client-transform machinery, so three
        real Quill editors can share one document with genuine concurrent
        typing, formatting, and deletion, and always converge on the same
        text, formatting, and embeds. SharedRichText is OT-backed; the
        CRDT-backed <a href="/text"><code>SharedText</code></a> handles plain
        text with grapheme identities and merge-based convergence.
      </p>
      <div class="cta-row">
        <a class="cta-quiet" href="#rt-demo">Jump to the demo ↓</a>
        <a class="cta-quiet" href="/text">Compare SharedText →</a>
        <a class="cta-quiet" href="https://github.com/tylerbutler/watershed">
          Read the source
        </a>
      </div>
    </div>
  </header>

  <main>
    <RichTextDemo />
  </main>
  <Ecosystem />
</Sheet>

<script>
  import { initReveals } from "../scripts/motion.js";
  initReveals();
</script>

<style>
  .page-hero {
    padding: clamp(3.5rem, 9vw, 7.5rem) var(--content-pad)
      clamp(2.5rem, 6vw, 5rem);
    border-bottom: 1px solid var(--hairline);
  }

  .page-hero-inner {
    max-width: 68rem;
    margin-inline: auto;
  }

  .eyebrow {
    color: var(--muted);
    margin: 0 0 var(--space-lg);
  }

  .eyebrow a {
    color: var(--waterline);
    text-decoration: none;
  }

  .eyebrow a:hover {
    color: var(--overprint-deep);
  }

  h1 {
    font-size: var(--text-display);
    font-weight: 640;
    font-stretch: 122%;
    line-height: 0.99;
    letter-spacing: -0.025em;
    max-width: 18ch;
  }

  h1 em {
    font-style: normal;
    color: var(--overprint-deep);
  }

  .lede {
    margin-top: var(--space-xl);
    font-size: clamp(1.125rem, 0.6vw + 1rem, 1.3125rem);
    line-height: 1.6;
    max-width: 58ch;
    color: var(--ink);
  }

  .cta-row {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg);
  }

  .cta-quiet {
    font-weight: 500;
    color: var(--waterline);
  }
</style>
