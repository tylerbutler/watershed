---
import Sheet from "../layouts/Sheet.astro";
import Hero from "../components/Hero.astro";
import Demo from "../components/Demo.astro";
import DdsSections from "../components/DdsSections.astro";
import AtlasCta from "../components/AtlasCta.astro";
import Architecture from "../components/Architecture.astro";
import Rigor from "../components/Rigor.astro";
import CodeSample from "../components/CodeSample.astro";
import Ecosystem from "../components/Ecosystem.astro";
---

<Sheet
  title="watershed — collaborative data structures for Gleam"
  description="A Gleam client toolkit for Fluid Framework distributed data structures: optimistic local edits, server-sequenced convergence, reconnect safety. One pure core, running on the BEAM and in the browser."
>
  <Hero />
  <main>
    <Demo views={["map"]} initial="map" showPicker={false}>
      <Fragment slot="intro">
        <p>
          On a photorevised survey sheet, magenta marks updates not yet
          field-checked. This demo borrows that color code: edits that aren’t
          confirmed yet are drawn in <strong class="k-pending">magenta</strong>,
          confirmed state in <strong class="k-seq">ink</strong>. All three
          clients run watershed’s real <code>map_kernel</code> Gleam code,
          sharing one ordered list of changes — a shared map, the collaborative
          structure most apps reach for first.
        </p>
        <p class="demo-hint">
          Nudge a gauge, have two clients write at once, stretch the network
          delay — the copies always agree, and the most recent write to a key
          wins.
        </p>
        <aside class="demo-bug-teaser">
          <p>
            <strong>…but “most recent write wins” has a famous failure mode.</strong>
            Store a <em>counter</em> in this map and have two people add to it at
            once — their increments silently overwrite each other instead of
            adding up. It’s the classic distributed-systems bug.
          </p>
          <a href="/counter-bug">Watch a boat vanish, live →</a>
        </aside>
        <p class="demo-hint">
          Every other structure runs the same way on its own page. Start with the
          <a href="/structures">field atlas</a> — the full catalog →
        </p>
      </Fragment>
    </Demo>
    <DdsSections />
    <AtlasCta />
    <Architecture />
    <CodeSample />
    <Rigor />
  </main>
  <Ecosystem />
</Sheet>

<script>
  import { initReveals } from "../scripts/motion.js";
  import { initHeroDrift } from "../scripts/hero-drift.js";
  initReveals();
  initHeroDrift();
</script>

<style>
  /* Teaser callout inside the SharedMap demo intro — the LWW-is-a-trap hook
     that routes to the dedicated /counter-bug page. Magenta = attention, the
     sheet's "unverified revision" cue. */
  .demo-bug-teaser {
    margin-top: var(--space-lg);
    padding: var(--space-md) var(--space-lg);
    border: 1px solid var(--overprint);
    background: var(--surface);
    max-width: 62ch;
  }

  .demo-bug-teaser p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--ink);
  }

  .demo-bug-teaser strong {
    color: var(--overprint-deep);
  }

  .demo-bug-teaser em {
    font-style: italic;
  }

  .demo-bug-teaser a {
    display: inline-block;
    margin-top: var(--space-xs);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--overprint-deep);
    text-decoration: none;
    border-bottom: 1px solid var(--overprint-faint);
  }

  .demo-bug-teaser a:hover {
    border-bottom-color: var(--overprint-deep);
  }
</style>
