---
import Sheet from "../layouts/Sheet.astro";
import Hero from "../components/Hero.astro";
import Demo from "../components/Demo.astro";
import DdsSections from "../components/DdsSections.astro";
import Architecture from "../components/Architecture.astro";
import Rigor from "../components/Rigor.astro";
import CodeSample from "../components/CodeSample.astro";
import Ecosystem from "../components/Ecosystem.astro";
---

<Sheet
  title="watershed — collaborative data structures for Gleam"
  description="A Gleam client toolkit for Fluid Framework distributed data structures: optimistic local edits, server-sequenced convergence, reconnect safety. One pure core, running on the BEAM and in the browser."
>
  <Hero />
  <main>
    <Demo />
    <DdsSections />
    <Architecture />
    <CodeSample />
    <Rigor />
  </main>
  <Ecosystem />
</Sheet>

<script>
  import { initReveals } from "../scripts/motion.js";
  import { initHeroDrift } from "../scripts/hero-drift.js";
  initReveals();
  initHeroDrift();
</script>
