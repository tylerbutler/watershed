---
import Sheet from "../../layouts/Sheet.astro";
import Ecosystem from "../../components/Ecosystem.astro";
import { categories } from "../../data/structures";
---

<Sheet
  title="watershed — data structures"
  description={`Field guide to watershed's collaborative data structures, grouped into families — ${categories
    .map((c) => c.name.toLowerCase())
    .join(", ")}. How each converges, and what it is best for.`}
>
  <header class="hub-hero">
    <div class="hub-hero-inner">
      <p class="eyebrow annot">
        <a href="/">← watershed</a> · Data structures
      </p>
      <h1>Every structure,<br /><em>by family.</em></h1>
      <p class="lede">
        Every structure watershed ships rides one server-sequenced stream, but
        each one converges by its own rule. This is the field guide: pick a
        family to see how each structure works, what it can render
        optimistically, and what it is best for.
      </p>
      <div class="cta-row">
        <a class="cta-quiet" href="/models">Compare DDS · CRDT · OT →</a>
        <a class="cta-quiet" href="/#demo">Watch them converge ↓</a>
      </div>
    </div>
  </header>

  <main class="families">
    {
      categories.map((c, i) => (
        <a class="family" href={`/structures/${c.slug}`} data-reveal="rise">
          <div class="family-top">
            <span class="family-index annot">
              Family {String(i + 1).padStart(2, "0")}
            </span>
            <h2>{c.name}</h2>
            <p class="family-tagline">{c.tagline}</p>
          </div>
          <ul class="family-list">
            {c.structures.map((s) => (
              <li>
                <code>{s.name}</code>
                <span class="kind" data-kind={s.kind}>
                  {s.kind}
                </span>
              </li>
            ))}
          </ul>
          <span class="family-go annot" aria-hidden="true">
            Open family →
          </span>
        </a>
      ))
    }
  </main>

  <Ecosystem />
</Sheet>

<script>
  import { initReveals } from "../../scripts/motion.js";
  initReveals();
</script>

<style>
  .hub-hero {
    padding: clamp(3.5rem, 9vw, 7rem) var(--content-pad) clamp(2.5rem, 6vw, 5rem);
    border-bottom: 1px solid var(--hairline);
  }

  .hub-hero-inner {
    max-width: 68rem;
    margin-inline: auto;
  }

  .eyebrow {
    color: var(--muted);
    margin: 0 0 var(--space-lg);
  }

  .eyebrow a {
    color: var(--waterline);
    text-decoration: none;
  }

  .eyebrow a:hover {
    color: var(--overprint-deep);
  }

  h1 {
    font-size: var(--text-display);
    font-weight: 640;
    font-stretch: 122%;
    line-height: 0.99;
    letter-spacing: -0.025em;
  }

  h1 em {
    font-style: normal;
    color: var(--overprint-deep);
  }

  /* Narrow screens: the 122% width expansion pushes "structures" past the sheet
     frame; relax it to normal width and tighten the size floor (matches the hero). */
  @media (max-width: 30rem) {
    h1 {
      font-size: clamp(1.9rem, 8.5vw, 2.7rem);
      font-stretch: 100%;
      letter-spacing: -0.03em;
    }
  }

  .lede {
    margin-top: var(--space-xl);
    font-size: clamp(1.125rem, 0.6vw + 1rem, 1.3125rem);
    line-height: 1.6;
    max-width: 58ch;
  }

  .cta-row {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }

  .cta-quiet {
    font-weight: 500;
    color: var(--waterline);
  }

  .families {
    max-width: 68rem;
    margin-inline: auto;
    padding: var(--space-2xl) var(--content-pad);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(19rem, 100%), 1fr));
    gap: var(--space-lg);
  }

  .family {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--ink);
    background: var(--bg);
    padding: var(--space-xl);
    text-decoration: none;
    color: var(--ink);
    transition:
      background var(--dur-state) var(--ease-out-quart),
      transform var(--dur-state) var(--ease-out-quart);
  }

  .family:hover {
    background: var(--surface);
    transform: translateY(-3px);
  }

  .family-index {
    color: var(--overprint-deep);
  }

  .family h2 {
    margin-top: var(--space-xs);
    font-size: 1.9rem;
    font-weight: 630;
    font-stretch: 116%;
    letter-spacing: -0.015em;
  }

  .family-tagline {
    margin-top: var(--space-xs);
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .family-list {
    margin: var(--space-lg) 0 var(--space-lg);
    padding: var(--space-md) 0 0;
    list-style: none;
    display: grid;
    gap: var(--space-xs);
    border-top: 1px solid var(--hairline);
    flex: 1;
  }

  .family-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .family-list code {
    font-size: 0.95rem;
    color: var(--ink);
  }

  .kind {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .kind[data-kind="CRDT"] {
    color: var(--waterline);
  }

  .family-go {
    color: var(--waterline);
  }

  .family:hover .family-go {
    color: var(--overprint-deep);
  }
</style>
