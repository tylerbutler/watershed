---
import Sheet from "../layouts/Sheet.astro";
import JsonOtDemo from "../components/JsonOtDemo.astro";
import Ecosystem from "../components/Ecosystem.astro";
---

<Sheet
  title="watershed — JSON operational transform demo"
  description="Three browser clients edit one shared JSON document through watershed's real json_ot kernel: optimistic edits, single-op-in-flight client transform, server-sequenced convergence. Concurrent list inserts have their indices transformed so every replica converges identically."
>
  <header class="page-hero">
    <div class="page-hero-inner">
      <p class="eyebrow annot">
        <a href="/">← watershed</a> · JSON operational transform
      </p>
      <h1>One document.<br />Concurrent edits. <em>One order.</em></h1>
      <p class="lede">
        The homepage shows CRDTs, which converge by merge rules. This is the
        other family: <strong>operational transform</strong>. watershed’s
        <code>json_ot</code> kernel is a faithful port of the ottypes
        <code>json0</code> algebra with the single-op-in-flight client protocol —
        every client edits a shared JSON document optimistically, a
        Fluid-compatible server sequences each op, and concurrent ops are
        <em>transformed</em> past one another so all replicas reach the same
        state, indices and all.
      </p>
      <div class="cta-row">
        <a class="cta-quiet" href="#jot-demo">Jump to the demo ↓</a>
        <a class="cta-quiet" href="https://github.com/tylerbutler/watershed">
          Read the source
        </a>
      </div>
    </div>
  </header>

  <main>
    <JsonOtDemo />
  </main>
  <Ecosystem />
</Sheet>

<script>
  import { initReveals } from "../scripts/motion.js";
  initReveals();
</script>

<style>
  .page-hero {
    padding: clamp(3.5rem, 9vw, 7.5rem) var(--content-pad)
      clamp(2.5rem, 6vw, 5rem);
    border-bottom: 1px solid var(--hairline);
  }

  .page-hero-inner {
    max-width: 68rem;
    margin-inline: auto;
  }

  .eyebrow {
    color: var(--muted);
    margin: 0 0 var(--space-lg);
  }

  .eyebrow a {
    color: var(--waterline);
    text-decoration: none;
  }

  .eyebrow a:hover {
    color: var(--overprint-deep);
  }

  h1 {
    font-size: var(--text-display);
    font-weight: 640;
    font-stretch: 122%;
    line-height: 0.99;
    letter-spacing: -0.025em;
    max-width: 16ch;
  }

  h1 em {
    font-style: normal;
    color: var(--overprint-deep);
  }

  .lede {
    margin-top: var(--space-xl);
    font-size: clamp(1.125rem, 0.6vw + 1rem, 1.3125rem);
    line-height: 1.6;
    max-width: 56ch;
    color: var(--ink);
  }

  .cta-row {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg);
  }

  .cta-quiet {
    font-weight: 500;
    color: var(--waterline);
  }
</style>
