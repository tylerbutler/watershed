---
import "@fontsource-variable/archivo/wdth.css";
import "@fontsource/fragment-mono";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

// Sheet-index navigation. On a photorevised quadrangle the margins carry the
// sheet's own index — the name, the legend, the adjoining-sheet references. Here
// they carry the site's: a persistent quick-jump printed in the top margin, the
// only nav that appears on every sheet. The "adjoining sheets" footer (in
// Ecosystem) is the full index; this is the always-there shortcut.
const nav = [
  { label: "Atlas", href: "/structures", match: "/structures" },
  { label: "Guide", href: "/guide", match: "/guide" },
  { label: "Models", href: "/models", match: "/models" },
  { label: "Runtime", href: "/runtime", match: "/runtime" },
] as const;

const path = Astro.url.pathname;
const isActive = (match: string) =>
  path === match || path.startsWith(`${match}/`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body>
    <header class="sheet-index">
      <a class="si-mark" href="/" aria-current={path === "/" ? "page" : undefined}>
        <span class="si-name">watershed</span>
        <span class="si-tag annot">Fluid DDS client toolkit</span>
      </a>
      <nav class="si-nav" aria-label="Sheet index">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class="si-link annot"
              aria-current={isActive(item.match) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
        <a
          class="si-link si-link-out annot"
          href="https://github.com/tylerbutler/watershed"
        >
          Source <span aria-hidden="true">↗</span>
        </a>
      </nav>
    </header>

    <div class="sheet">
      <span class="reg reg-tl" aria-hidden="true"></span>
      <span class="reg reg-tr" aria-hidden="true"></span>
      <span class="reg reg-bl" aria-hidden="true"></span>
      <span class="reg reg-br" aria-hidden="true"></span>
      <slot />
    </div>

    <div class="margin-row margin-bottom annot" aria-hidden="true">
      <span>Magenta indicates revisions not yet field-checked</span>
      <span class="margin-mid">Convergence guaranteed by server sequencing</span>
      <span>tylerbutler.com</span>
    </div>
  </body>
</html>

<style>
  /* ── sheet-index nav (top margin, outside the neatline) ─────────────────── */
  .sheet-index {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-xs) var(--space-lg);
    margin: 0 var(--sheet-gutter);
    padding: 0.55rem 2px;
  }

  .si-mark {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    text-decoration: none;
    color: var(--ink);
  }

  .si-name {
    font-family: var(--font-mono);
    font-size: 0.9375rem;
    letter-spacing: -0.01em;
    color: var(--ink);
  }

  .si-mark:hover .si-name {
    color: var(--overprint-deep);
  }

  .si-tag {
    color: var(--muted);
  }

  /* below the neatline width, the tagline drops so the wordmark + nav fit */
  @media (max-width: 620px) {
    .si-tag {
      display: none;
    }
  }

  .si-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-xs) var(--space-lg);
  }

  .si-link {
    position: relative;
    text-decoration: none;
    color: var(--muted);
    padding-bottom: 0.15rem;
    transition: color var(--dur-feedback) var(--ease-out-quart);
  }

  .si-link:hover {
    color: var(--overprint-deep);
  }

  /* active sheet: printed in ink with a registration tick underneath */
  .si-link[aria-current="page"] {
    color: var(--ink);
  }

  .si-link[aria-current="page"]::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1.5px;
    background: var(--overprint);
  }

  .si-link-out {
    color: var(--waterline);
  }

  .si-link-out:hover {
    color: var(--overprint-deep);
  }

  .margin-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-md);
    margin: 0 var(--sheet-gutter);
    padding: 0.6rem 2px;
  }

  .margin-mid {
    text-align: center;
  }

  .margin-bottom span:first-child {
    color: var(--overprint-deep);
  }

  @media (max-width: 720px) {
    .margin-mid {
      display: none;
    }
  }

  /* narrowest sheets: one annotation per margin row so the frame stays a
     single line below the neatline */
  @media (max-width: 540px) {
    .margin-bottom span:last-child {
      display: none;
    }
  }

  .sheet {
    position: relative;
    margin: 0 var(--sheet-gutter);
    border: 1px solid var(--ink);
    background: var(--bg);
  }

  /* registration crosses at the neatline corners */
  .reg {
    position: absolute;
    width: 17px;
    height: 17px;
    pointer-events: none;
    background:
      linear-gradient(var(--ink), var(--ink)) center / 1px 100% no-repeat,
      linear-gradient(var(--ink), var(--ink)) center / 100% 1px no-repeat;
  }

  .reg-tl {
    top: -8.5px;
    left: -8.5px;
  }

  .reg-tr {
    top: -8.5px;
    right: -8.5px;
  }

  .reg-bl {
    bottom: -8.5px;
    left: -8.5px;
  }

  .reg-br {
    bottom: -8.5px;
    right: -8.5px;
  }
</style>
