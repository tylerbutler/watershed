---
// Contour field markup is generated at build time from the shared generator;
// hero-drift.js re-derives the same geometry on the client to keep the lines
// slowly flexing after the draw-in.
import { W, H, ROWS, contourPath } from "../scripts/contour-field.js";

const contours = Array.from({ length: ROWS }, (_, i) => ({
  d: contourPath(i),
  index: i % 4 === 1, // every 4th is an index contour
  sn: 1240 - i * 20,
}));
---

<header class="hero">
  <svg
    class="contours"
    data-contour-field
    viewBox={`0 0 ${W} ${H}`}
    preserveAspectRatio="xMaxYMid slice"
    aria-hidden="true"
  >
    {
      contours.map((c, i) => (
        <>
          <path
            id={`contour-${i}`}
            class:list={["contour", { index: c.index }]}
            d={c.d}
            style={`--i: ${i}`}
          />
          {c.index && (
            <text class="contour-label" dy="-4">
              <textPath href={`#contour-${i}`} startOffset={`${64 + i * 2}%`}>
                SN {c.sn}
              </textPath>
            </text>
          )}
        </>
      ))
    }
  </svg>

  <div class="hero-inner">
    <h1>
      Edit upstream.<br />Converge <em>downstream.</em>
    </h1>
    <p class="lede">
      watershed is a Gleam client toolkit for Fluid Framework distributed data
      structures. Clients edit locally without waiting; a Fluid-compatible server
      sequences every op; every replica reaches the same state — on the BEAM and
      in the browser, from one pure core.
    </p>
    <div class="cta-row">
      <a class="cta-primary" href="https://github.com/tylerbutler/watershed">
        View on GitHub
      </a>
      <a class="cta-quiet" href="#demo">Watch two clients converge ↓</a>
    </div>
  </div>
</header>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(4.5rem, 11vw, 9.5rem) var(--content-pad)
      clamp(4rem, 9vw, 8rem);
    border-bottom: 1px solid var(--hairline);
  }

  .contours {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    /* fade the field out under the headline so the type stays legible */
    mask-image: linear-gradient(
      100deg,
      transparent 26%,
      oklch(0 0 0 / 0.5) 48%,
      black 72%
    );
  }

  .contour {
    fill: none;
    stroke: var(--waterline-faint);
    stroke-width: 1;
    stroke-dasharray: 3200;
    stroke-dashoffset: 3200;
    animation: draw 2.4s var(--ease-out-quart) forwards;
    animation-delay: calc(120ms + var(--i) * 90ms);
  }

  .contour.index {
    stroke: var(--overprint);
    stroke-width: 1.4;
  }

  .contour-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    fill: var(--overprint-deep);
    opacity: 0;
    animation: fade-in 0.9s var(--ease-out-quart) 1.6s forwards;
  }

  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes fade-in {
    to {
      opacity: 1;
    }
  }

  .hero-inner {
    position: relative;
    max-width: 68rem;
    margin-inline: auto;
  }

  h1 {
    font-size: var(--text-display);
    font-weight: 640;
    font-stretch: 122%;
    line-height: 0.99;
    letter-spacing: -0.025em;
    max-width: 12ch;
    animation: rise var(--dur-entrance) var(--ease-out-expo) both;
  }

  h1 em {
    font-style: normal;
    color: var(--overprint-deep);
  }

  .lede {
    margin-top: var(--space-xl);
    font-size: clamp(1.125rem, 0.6vw + 1rem, 1.3125rem);
    line-height: 1.6;
    max-width: 52ch;
    color: var(--ink);
    animation: rise var(--dur-entrance) var(--ease-out-expo) 140ms both;
  }

  .cta-row {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg);
    animation: rise var(--dur-entrance) var(--ease-out-expo) 240ms both;
  }

  .cta-primary {
    display: inline-block;
    padding: 0.8rem 1.6rem;
    background: var(--overprint);
    color: oklch(100% 0 0);
    text-decoration: none;
    font-weight: 600;
    font-stretch: 110%;
    letter-spacing: 0.01em;
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      transform var(--dur-feedback) var(--ease-out-quart);
  }

  .cta-primary:hover {
    background: var(--overprint-deep);
    color: oklch(100% 0 0);
  }

  .cta-primary:active {
    transform: scale(0.97);
  }

  .cta-quiet {
    font-weight: 500;
    color: var(--waterline);
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(18px);
    }

    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (max-width: 720px) {
    /* keep the field out from under the copy: bottom band only */
    .contours {
      mask-image: linear-gradient(
        transparent 0%,
        transparent 62%,
        oklch(0 0 0 / 0.55) 78%,
        black 94%
      );
    }
  }
</style>
