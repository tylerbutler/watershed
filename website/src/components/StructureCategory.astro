---
import Sheet from "../layouts/Sheet.astro";
import Ecosystem from "../components/Ecosystem.astro";
import Demo from "../components/Demo.astro";
import { categories, structuresBySlug } from "../data/structures";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const category = structuresBySlug[slug];
if (!category) {
  throw new Error(`Unknown structure category: ${slug}`);
}

const idx = categories.findIndex((c) => c.slug === slug);
const prev = idx > 0 ? categories[idx - 1] : categories[categories.length - 1];
const next =
  idx < categories.length - 1 ? categories[idx + 1] : categories[0];
const familyOrdinal = `Family ${String(idx + 1).padStart(2, "0")}`;

// Scope the shared live demo to this family's structures. Structures with a
// dedicated demo page (e.g. SharedDirectory's tree) aren't views in the shared
// gauge demo, so they're excluded here and link to their own demo instead.
const familyViews = category.structures
  .filter((s) => !s.demoHref)
  .map((s) => s.id);
---

<Sheet
  title={`watershed — ${category.name.toLowerCase()}`}
  description={`${category.name} in watershed: ${category.tagline} ${category.structures
    .map((s) => s.name)
    .join(", ")}. How each works, its merge rule, and what it is best for.`}
>
  <header class="cat-hero">
    <div class="cat-hero-inner">
      <p class="eyebrow annot">
        <a href="/">← watershed</a> · <a href="/structures">Data structures</a> /
        {category.name}
      </p>
      <div class="cat-title">
        <h1>{category.name}</h1>
        <span class="cat-index annot" aria-hidden="true">{familyOrdinal}</span>
      </div>
      <p class="cat-tagline">{category.tagline}</p>
      {category.lede.map((para) => <p class="lede">{para}</p>)}

      <nav class="jump" aria-label={`${category.name} in this family`}>
        {
          category.structures.map((s) => (
            <a href={`#${s.id}`}>
              <code>{s.name}</code>
              <span class="jump-kind annot" data-kind={s.kind}>
                {s.kind}
              </span>
            </a>
          ))
        }
      </nav>
    </div>
  </header>

  {
    familyViews.length > 0 && (
      <Demo
        views={familyViews}
        initial={familyViews[0]}
        heading={`Watch ${category.name.toLowerCase()} converge`}
        otJump={false}
      >
        <Fragment slot="intro">
          <p>
            Every structure in this family runs live below, on watershed’s real
            Gleam kernels. Pending edits print in
            <strong class="k-pending">magenta</strong>; once the sequencer stamps
            an SN, every replica lands the same <strong class="k-seq">ink</strong>
            state. Switch structures with the picker — all of them share one
            ordered stream, exactly like DDSes in a single container.
          </p>
          <p class="demo-hint">
            Nudge a value, race a concurrent write, or stretch the link latency
            to watch each merge rule hold.
          </p>
        </Fragment>
      </Demo>
    )
  }

  <main class="plates">
    {
      category.structures.map((s, i) => (
        <article class="plate" id={s.id} data-reveal="rise">
          <div class="plate-mark annot" aria-hidden="true">
            No. {String(i + 1).padStart(2, "0")}
          </div>
          <header class="plate-head">
            <div class="plate-name">
              <h2>{s.name}</h2>
              <span class="stamp" data-kind={s.kind}>
                {s.kind}
              </span>
            </div>
            <code class="plate-module">{s.module}</code>
            <p class="plate-tagline">{s.tagline}</p>
            {
              s.demoHref && (
                <a class="plate-demo" href={s.demoHref}>
                  Open the live {s.name} demo →
                </a>
              )
            }
          </header>

          <div class="plate-body">
            <div class="plate-prose">
              {s.how.map((para) => (
                <p>{para}</p>
              ))}

              <h3 class="uses-title annot">Best for</h3>
              <ul class="uses">
                {s.useCases.map((use) => (
                  <li>{use}</li>
                ))}
              </ul>
            </div>

            <dl class="spec">
              <div>
                <dt>Merge rule</dt>
                <dd>{s.rule}</dd>
              </div>
              <div>
                <dt>Optimistic behavior</dt>
                <dd>{s.optimistic}</dd>
              </div>
              <div>
                <dt>Summary shape</dt>
                <dd>{s.summary}</dd>
              </div>
              <div>
                <dt>Model</dt>
                <dd>
                  {s.kind === "CRDT"
                    ? "Conflict-free replicated data type — converges by merge"
                    : "Distributed data structure — converges by server order"}
                </dd>
              </div>
            </dl>
          </div>
        </article>
      ))
    }
  </main>

  <nav class="cat-nav" aria-label="More on data structures">
    <a class="cat-nav-side" href={`/structures/${prev.slug}`}>
      <span class="annot">← Previous family</span>
      <strong>{prev.name}</strong>
    </a>
    <div class="cat-nav-mid">
      <a href="/structures">All families</a>
      <a href="/models">DDS vs CRDT vs OT →</a>
      <a href="/#demo">See it live ↓</a>
    </div>
    <a class="cat-nav-side cat-nav-next" href={`/structures/${next.slug}`}>
      <span class="annot">Next family →</span>
      <strong>{next.name}</strong>
    </a>
  </nav>

  <Ecosystem />
</Sheet>

<script>
  import { initReveals } from "../scripts/motion.js";
  initReveals();
</script>

<style>
  /* ── hero ─────────────────────────────────────────────────────────────── */
  .cat-hero {
    padding: clamp(3rem, 8vw, 6.5rem) var(--content-pad) clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--hairline);
    background:
      linear-gradient(var(--hairline-faint) 1px, transparent 1px),
      linear-gradient(90deg, var(--hairline-faint) 1px, transparent 1px),
      var(--surface);
    background-size: 3.5rem 3.5rem;
  }

  .cat-hero-inner {
    max-width: 68rem;
    margin-inline: auto;
  }

  .eyebrow {
    color: var(--muted);
    margin: 0 0 var(--space-lg);
  }

  .eyebrow a {
    color: var(--waterline);
    text-decoration: none;
  }

  .eyebrow a:hover {
    color: var(--overprint-deep);
  }

  .cat-title {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-sm) var(--space-lg);
    flex-wrap: wrap;
  }

  h1 {
    font-size: var(--text-display);
    font-weight: 640;
    font-stretch: 122%;
    line-height: 0.99;
    letter-spacing: -0.025em;
    overflow-wrap: break-word;
  }

  @media (max-width: 30rem) {
    h1 {
      font-size: clamp(2.1rem, 10vw, 2.7rem);
      font-stretch: 100%;
      letter-spacing: -0.03em;
    }
  }

  .cat-index {
    color: var(--overprint-deep);
    white-space: nowrap;
  }

  .cat-tagline {
    margin-top: var(--space-md);
    font-size: clamp(1.2rem, 0.8vw + 1rem, 1.5rem);
    font-stretch: 112%;
    color: var(--ink);
    max-width: 40ch;
  }

  .lede {
    margin-top: var(--space-lg);
    font-size: clamp(1.0625rem, 0.4vw + 1rem, 1.2rem);
    line-height: 1.6;
    max-width: 60ch;
    color: var(--ink);
  }

  .jump {
    margin-top: var(--space-xl);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .jump a {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--ink);
    background: var(--bg);
    text-decoration: none;
    color: var(--ink);
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      color var(--dur-feedback) var(--ease-out-quart);
  }

  .jump a:hover {
    background: var(--ink);
    color: var(--bg);
  }

  .jump a:hover code {
    color: var(--bg);
  }

  .jump code {
    font-size: 0.9rem;
    color: var(--ink);
  }

  .jump-kind {
    font-size: 0.66rem;
  }

  .jump-kind[data-kind="CRDT"] {
    color: var(--waterline);
  }

  .jump-kind[data-kind="DDS"] {
    color: var(--muted);
  }

  .jump a:hover .jump-kind {
    color: var(--bg);
  }

  /* ── plates ───────────────────────────────────────────────────────────── */
  .plates {
    max-width: 68rem;
    margin-inline: auto;
    padding: var(--space-2xl) var(--content-pad);
    display: grid;
    gap: var(--space-2xl);
  }

  .plate {
    position: relative;
    border: 1px solid var(--ink);
    background: var(--bg);
    padding: clamp(var(--space-lg), 3vw, var(--space-2xl));
    min-width: 0;
  }

  .plate-mark {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    color: var(--muted);
  }

  .plate-head {
    padding-right: 4rem;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: var(--space-lg);
  }

  .plate-name {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  h2 {
    font-size: var(--text-h2);
    font-weight: 630;
    font-stretch: 116%;
    letter-spacing: -0.015em;
    line-height: 1.05;
    overflow-wrap: anywhere;
  }

  .stamp {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.18rem 0.5rem;
    border: 1.5px solid currentColor;
    color: var(--muted);
    transform: rotate(-2deg);
  }

  .stamp[data-kind="CRDT"] {
    color: var(--waterline);
  }

  .stamp[data-kind="DDS"] {
    color: var(--ink);
  }

  .stamp[data-kind="OT"] {
    color: var(--overprint-deep);
  }

  .plate-module {
    display: inline-block;
    margin-top: var(--space-sm);
    color: var(--overprint-deep);
    font-size: 0.85rem;
  }

  .plate-tagline {
    margin-top: var(--space-sm);
    color: var(--muted);
    font-size: var(--text-body);
    max-width: 54ch;
  }

  .plate-demo {
    display: inline-block;
    margin-top: var(--space-md);
    font-weight: 600;
    color: var(--waterline);
    text-decoration: none;
  }

  .plate-demo:hover {
    color: var(--overprint-deep);
  }

  .plate-body {
    margin-top: var(--space-lg);
    display: grid;
    grid-template-columns: minmax(0, 1.55fr) minmax(15rem, 1fr);
    gap: clamp(var(--space-lg), 4vw, var(--space-2xl));
    align-items: start;
  }

  .plate-prose p {
    max-width: 60ch;
    color: var(--ink);
  }

  .plate-prose p + p {
    margin-top: var(--space-md);
  }

  .uses-title {
    margin: var(--space-xl) 0 var(--space-sm);
    color: var(--overprint-deep);
  }

  .uses {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-xs);
  }

  .uses li {
    position: relative;
    padding-left: 1.4rem;
    color: var(--ink);
    font-size: var(--text-sm);
    max-width: 58ch;
  }

  .uses li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--waterline);
  }

  .spec {
    margin: 0;
    border: 1px solid var(--ink);
    background: var(--surface);
    position: relative;
  }

  .spec::after {
    content: "";
    position: absolute;
    inset: var(--space-xs);
    border: 1px dashed var(--hairline);
    pointer-events: none;
  }

  .spec div {
    position: relative;
    z-index: 1;
    padding: var(--space-md) var(--space-lg);
  }

  .spec div + div {
    border-top: 1px solid var(--hairline);
  }

  .spec dt {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .spec dd {
    margin: var(--space-2xs) 0 0;
    color: var(--ink);
    font-size: var(--text-sm);
    line-height: 1.5;
    text-wrap: pretty;
  }

  /* ── bottom nav ───────────────────────────────────────────────────────── */
  .cat-nav {
    max-width: 68rem;
    margin-inline: auto;
    padding: var(--space-xl) var(--content-pad) var(--space-2xl);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-lg);
    border-top: 1px solid var(--hairline);
  }

  .cat-nav-side {
    display: grid;
    gap: 0.1rem;
    text-decoration: none;
    color: var(--ink);
  }

  .cat-nav-side .annot {
    color: var(--muted);
  }

  .cat-nav-side strong {
    font-stretch: 112%;
    font-weight: 620;
    color: var(--waterline);
  }

  .cat-nav-side:hover strong {
    color: var(--overprint-deep);
  }

  .cat-nav-next {
    text-align: right;
    justify-items: end;
  }

  .cat-nav-mid {
    display: grid;
    gap: var(--space-2xs);
    justify-items: center;
    text-align: center;
    font-size: var(--text-sm);
  }

  @media (max-width: 720px) {
    .plate-body {
      grid-template-columns: 1fr;
    }

    .cat-nav {
      grid-template-columns: 1fr;
      justify-items: start;
      gap: var(--space-lg);
    }

    .cat-nav-next {
      text-align: left;
      justify-items: start;
    }

    .cat-nav-mid {
      justify-items: start;
      text-align: left;
      order: 3;
    }
  }

  @media (max-width: 480px) {
    .plate {
      padding: var(--space-lg) var(--space-md);
    }

    .plate-head {
      padding-right: 2.75rem;
    }

    .plate-mark {
      top: var(--space-sm);
      right: var(--space-sm);
    }

    h2 {
      font-size: clamp(1.5rem, 6.5vw, 1.9rem);
    }
  }
</style>
