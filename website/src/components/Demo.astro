---
const gauges = [
  { key: "mill-race", value: 24 },
  { key: "kettle-run", value: 61 },
  { key: "low-ford", value: 42 },
];
const counter = { key: "sandbags-placed", value: 120 };
const pn = { key: "earthwork-balance", fill: 74, cut: 30 };
const clients = [
  { id: "a", name: "Client A" },
  { id: "b", name: "Client B" },
];
const counterSteps = [-5, -1, 1, 5];
const pnCutSteps = [-6, -2];
const pnFillSteps = [2, 6];
---

<section id="demo" class="demo" aria-labelledby="demo-title">
  <div class="demo-head">
    <h2 id="demo-title">Photorevision, live</h2>
    <p>
      On a photorevised survey sheet, magenta marks updates that haven’t been
      field-checked yet. watershed prints its state the same way: a local edit
      applies instantly and shows <strong class="k-pending">magenta</strong> while
      it is pending, then sets in <strong class="k-seq">ink</strong> once the
      server assigns it a sequence number. The two clients below run the real
      <code>map_kernel</code>, <code>counter_kernel</code>, and
      <code>pn_counter_kernel</code> — the same Gleam modules the BEAM runtime
      uses, compiled to JavaScript — riding one sequencer on this page.
    </p>
    <p class="demo-hint">
      Nudge the gauges, tally the sandbags, balance the earthwork, stretch the
      link latency, race a concurrent write. The replicas always converge —
      each structure by its own rule.
    </p>
  </div>

  <div class="dds-switch">
    <fieldset class="dds-picker" data-dds-picker>
      <legend class="visually-hidden">Data structure shown in both clients</legend>
      <label>
        <input type="radio" name="dds" value="map" checked data-dds-pick disabled />
        <span>Shared map</span>
      </label>
      <label>
        <input type="radio" name="dds" value="counter" data-dds-pick disabled />
        <span>Shared counter</span>
      </label>
      <label>
        <input type="radio" name="dds" value="pn" data-dds-pick disabled />
        <span>PN counter</span>
      </label>
    </fieldset>
    <p class="merge-rule" data-merge-rule="map">
      <strong>Merge rule — last write wins.</strong> Race two writes to the
      same key and the op the sequencer stamps later overwrites the earlier
      one, identically on every replica.
    </p>
    <p class="merge-rule" data-merge-rule="counter" hidden>
      <strong>Merge rule — increments commute.</strong> Race two increments
      and both apply. The counter converges on the sum; nothing is
      overwritten.
    </p>
    <p class="merge-rule" data-merge-rule="pn" hidden>
      <strong>Merge rule — deltas join a lattice.</strong> Every update
      travels as a CRDT delta; merging is commutative and idempotent. Race
      it, resend it, deliver it twice — it counts exactly once, and the
      balance converges on fill&nbsp;−&nbsp;cut.
    </p>
  </div>

  <div class="rig" data-demo-rig data-dds="map">
    {
      clients.map((c) => (
        <article
          class="client"
          data-client={c.id}
          aria-label={`${c.name} replica`}
          style={`grid-area: ${c.id}`}
        >
          <header class="client-head">
            <h3>{c.name}</h3>
            <span
              class="pending-count annot"
              data-pending-count
              data-live={c.id}
            >
              0 pending
            </span>
          </header>
          <table class="gauge-table dds-map">
            <caption class="visually-hidden">
              Shared map replica on {c.name}
            </caption>
            <tbody>
              {gauges.map((g) => (
                <tr data-key={g.key}>
                  <th scope="row">
                    <code>{g.key}</code>
                  </th>
                  <td class="gauge-value" data-value>
                    {g.value}
                  </td>
                  <td class="gauge-actions">
                    <button
                      type="button"
                      data-step="-1"
                      aria-label={`Lower ${g.key} on ${c.name}`}
                      disabled
                    >
                      −
                    </button>
                    <button
                      type="button"
                      data-step="1"
                      aria-label={`Raise ${g.key} on ${c.name}`}
                      disabled
                    >
                      +
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <div
            class="counter-panel dds-counter"
            role="group"
            aria-label={`Shared counter replica on ${c.name}`}
          >
            <code class="counter-key">{counter.key}</code>
            <output class="counter-value" data-counter-value>
              {counter.value}
            </output>
            <span
              class="counter-delta annot"
              data-counter-delta
              aria-label="Pending unsequenced delta"
            ></span>
            <div class="counter-actions">
              {counterSteps.map((step) => (
                <button
                  type="button"
                  data-inc={step}
                  aria-label={`${step > 0 ? "Add" : "Remove"} ${Math.abs(step)} ${Math.abs(step) === 1 ? "sandbag" : "sandbags"} on ${c.name}`}
                  disabled
                >
                  {step > 0 ? `+${step}` : `−${Math.abs(step)}`}
                </button>
              ))}
            </div>
          </div>
          <div
            class="counter-panel dds-pn"
            role="group"
            aria-label={`PN counter replica on ${c.name}`}
          >
            <code class="counter-key">{pn.key} · yd³</code>
            <output class="counter-value" data-pn-value>
              +{pn.fill - pn.cut}
            </output>
            <span
              class="counter-delta annot"
              data-pn-delta
              aria-label="Pending unsequenced delta"
            ></span>
            <dl class="pn-ledger">
              <div>
                <dt class="annot">fill Σ</dt>
                <dd data-pn-fill>{pn.fill}</dd>
              </div>
              <div>
                <dt class="annot">cut Σ</dt>
                <dd data-pn-cut>{pn.cut}</dd>
              </div>
            </dl>
            <div class="counter-actions pn-actions">
              <span class="annot" aria-hidden="true">cut</span>
              {pnCutSteps.map((step) => (
                <button
                  type="button"
                  data-pn-inc={step}
                  aria-label={`Cut ${Math.abs(step)} cubic yards on ${c.name}`}
                  disabled
                >
                  −{Math.abs(step)}
                </button>
              ))}
              {pnFillSteps.map((step) => (
                <button
                  type="button"
                  data-pn-inc={step}
                  aria-label={`Fill ${step} cubic yards on ${c.name}`}
                  disabled
                >
                  +{step}
                </button>
              ))}
              <span class="annot" aria-hidden="true">fill</span>
            </div>
          </div>
        </article>
      ))
    }

    <div class="channel" style="grid-area: seq">
      <div class="seq-node" data-seq-node>
        <span class="annot">Sequencer</span>
        <output class="seq-counter" data-seq-counter aria-label="Latest sequence number">
          SN&nbsp;0
        </output>
      </div>
      <ol
        class="op-log"
        data-op-log
        aria-live="polite"
        aria-label="Sequenced operations, newest first"
      >
      </ol>
    </div>

    <div class="flow-layer" data-flow-layer aria-hidden="true"></div>
  </div>

  <div class="demo-controls">
    <label class="latency">
      <span class="annot">Link latency</span>
      <input
        type="range"
        min="100"
        max="2000"
        step="100"
        value="700"
        data-latency
        disabled
      />
      <output data-latency-out>700 ms</output>
    </label>
    <button type="button" class="race-btn" data-race disabled>
      Race a concurrent write
    </button>
    <button
      type="button"
      class="race-btn"
      data-replay
      aria-label="Deliver the most recently sequenced delta a second time to both replicas"
      hidden
      disabled
    >
      Re-deliver last delta
    </button>
    <button
      type="button"
      class="reset-btn"
      data-reset
      aria-label="Reset all gauges to their surveyed baseline values"
      disabled
    >
      Reset survey
    </button>
    <p class="status" data-status role="status">
      <span class="stamp converged">Converged</span>
      replicas identical · nothing pending
    </p>
  </div>

  <noscript>
    <p class="demo-noscript">
      The live demo needs JavaScript — it runs watershed’s actual
      <code>map_kernel</code>, <code>counter_kernel</code>, and
      <code>pn_counter_kernel</code> in your browser. The rest of the page
      works fine without it.
    </p>
  </noscript>

  <p class="demo-noscript" data-demo-fallback hidden>
    The live demo couldn’t start — it runs watershed’s actual kernels as
    compiled JavaScript modules, and this browser didn’t load them. The rest
    of the page works fine without it.
  </p>
</section>

<script>
  try {
    const { initDemo } = await import("../scripts/demo.js");
    initDemo();
  } catch (error) {
    console.error("watershed demo failed to start", error);
    const note = document.querySelector("[data-demo-fallback]");
    if (note instanceof HTMLElement) note.hidden = false;
  }
</script>

<style>
  .demo {
    padding: var(--space-section) var(--content-pad);
    border-bottom: 1px solid var(--hairline);
  }

  .demo-head {
    max-width: 68rem;
    margin-inline: auto;
  }

  h2 {
    font-size: var(--text-h2);
    font-weight: 620;
    font-stretch: 118%;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .demo-head p {
    margin-top: var(--space-lg);
  }

  .demo-hint {
    color: var(--ink);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .k-pending {
    color: var(--overprint-deep);
  }

  .k-seq {
    color: var(--ink);
  }

  .dds-switch {
    max-width: 68rem;
    margin: var(--space-xl) auto 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    column-gap: var(--space-xl);
    row-gap: var(--space-md);
  }

  .dds-picker {
    display: flex;
    border: 1px solid var(--ink);
    padding: 0;
    margin: 0;
    width: max-content;
  }

  .dds-picker label {
    position: relative;
    padding: 0.55rem 1.15rem;
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      color var(--dur-feedback) var(--ease-out-quart);
  }

  .dds-picker label + label {
    border-inline-start: 1px solid var(--ink);
  }

  /* radio stays in the tree (focusable, arrow-key switchable), drawn by label */
  .dds-picker input {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    pointer-events: none;
  }

  .dds-picker label:has(input:checked) {
    background: var(--ink);
    color: var(--bg);
  }

  .dds-picker label:hover:not(:has(input:checked)):not(:has(input:disabled)) {
    background: var(--surface);
  }

  .dds-picker label:has(input:focus-visible) {
    outline: 2px solid var(--overprint);
    outline-offset: 2px;
  }

  .dds-picker label:has(input:disabled) {
    opacity: 0.45;
    cursor: default;
  }

  .merge-rule {
    font-size: var(--text-sm);
    color: var(--muted);
    max-width: 52ch;
  }

  .merge-rule strong {
    color: var(--ink);
  }

  .rig {
    position: relative;
    max-width: 68rem;
    margin: var(--space-lg) auto 0;
    display: grid;
    grid-template-areas: "a seq b";
    grid-template-columns: 1fr minmax(11rem, 0.7fr) 1fr;
    gap: var(--space-lg);
    align-items: stretch;
  }

  .client {
    border: 1px solid var(--ink);
    background: var(--bg);
    display: flex;
    flex-direction: column;
  }

  .client-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--hairline);
  }

  .client-head h3 {
    font-size: 1rem;
    font-weight: 650;
    font-stretch: 115%;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .pending-count {
    color: var(--overprint-deep);
    transition: color var(--dur-state) var(--ease-out-quart);
  }

  /* idle stays full-strength --muted (7.7:1); magenta alone marks pending */
  .pending-count[data-zero] {
    color: var(--muted);
  }

  .gauge-table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-xs) 0 var(--space-sm);
  }

  .gauge-table th,
  .gauge-table td {
    padding: var(--space-sm) var(--space-md);
    text-align: left;
    font-weight: 400;
  }

  .gauge-table code {
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .gauge-value {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-variant-numeric: tabular-nums;
    text-align: right;
    color: var(--ink);
    transition: color var(--dur-state) var(--ease-out-quart);
  }

  /* pending = magenta overprint, italic like a hand-annotated revision */
  tr.pending .gauge-value {
    color: var(--overprint-deep);
    font-style: italic;
  }

  .gauge-actions {
    white-space: nowrap;
    text-align: right;
    width: 1%;
  }

  .gauge-actions button {
    inline-size: 2.4rem;
    block-size: 2.4rem;
    border: 1px solid var(--ink);
    background: var(--bg);
    font-size: 1.2rem;
    line-height: 1;
    cursor: pointer;
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      transform var(--dur-feedback) var(--ease-out-quart);
  }

  .gauge-actions button:hover:enabled {
    background: var(--surface);
  }

  .gauge-actions button:active:enabled {
    transform: scale(0.94);
    background: var(--overprint-faint);
  }

  .gauge-actions button + button {
    margin-inline-start: var(--space-2xs);
  }

  /* one rig, three structures: the picker swaps which replica view is printed */
  .rig[data-dds="map"] .dds-counter,
  .rig[data-dds="map"] .dds-pn,
  .rig[data-dds="counter"] .dds-map,
  .rig[data-dds="counter"] .dds-pn,
  .rig[data-dds="pn"] .dds-map,
  .rig[data-dds="pn"] .dds-counter {
    display: none;
  }

  .counter-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xs);
    padding: var(--space-lg) var(--space-md) var(--space-xl);
  }

  .counter-key {
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .counter-value {
    font-family: var(--font-mono);
    font-size: 2.6rem;
    line-height: 1.15;
    font-variant-numeric: tabular-nums;
    color: var(--ink);
    transition: color var(--dur-state) var(--ease-out-quart);
  }

  .counter-value.pending {
    color: var(--overprint-deep);
    font-style: italic;
  }

  /* the pending state of a counter is a delta — annotated like an overprint */
  .counter-delta {
    color: var(--overprint-deep);
    min-height: 1.5em;
  }

  .counter-actions {
    margin-top: var(--space-sm);
    display: flex;
    gap: var(--space-2xs);
  }

  .counter-actions button {
    min-inline-size: 2.6rem;
    block-size: 2.4rem;
    padding-inline: 0.5rem;
    border: 1px solid var(--ink);
    background: var(--bg);
    font-size: 1rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    line-height: 1;
    cursor: pointer;
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      transform var(--dur-feedback) var(--ease-out-quart);
  }

  .counter-actions button:hover:enabled {
    background: var(--surface);
  }

  .counter-actions button:active:enabled {
    transform: scale(0.94);
    background: var(--overprint-faint);
  }

  /* the PN ledger prints the lattice's two monotone tallies side by side */
  .pn-ledger {
    display: flex;
    gap: var(--space-lg);
    margin: var(--space-2xs) 0 0;
  }

  .pn-ledger div {
    display: flex;
    align-items: baseline;
    gap: var(--space-xs);
  }

  .pn-ledger dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-variant-numeric: tabular-nums;
    color: var(--ink);
  }

  /* cut ‹ buttons › fill — the sign convention printed in the margin */
  .pn-actions {
    align-items: center;
  }

  .pn-actions .annot {
    font-size: 0.7rem;
  }

  .channel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding-top: clamp(var(--space-md), 6vw, 4.5rem);
  }

  .seq-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--ink);
    border-radius: 999px;
    background: var(--bg);
  }

  .seq-counter {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-variant-numeric: tabular-nums;
    color: var(--ink);
  }

  .seq-counter.stamped {
    animation: stamp 380ms var(--ease-out-quart);
  }

  @keyframes stamp {
    0% {
      color: var(--overprint);
      transform: scale(1.12);
    }

    100% {
      color: var(--ink);
      transform: none;
    }
  }

  .op-log {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.9;
    color: var(--muted);
    overflow: hidden;
    max-height: 12.5rem;
    mask-image: linear-gradient(black 55%, transparent 96%);
  }

  .op-log :global(li) {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
  }

  .op-log :global(li:first-child) {
    color: var(--ink);
  }

  /* a re-delivered duplicate is a non-event: logged, absorbed, italic */
  .op-log :global(li.replay) {
    color: var(--muted);
    font-style: italic;
  }

  .flow-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: var(--z-flow);
  }

  :global(.flow-dot) {
    position: absolute;
    top: 0;
    left: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--overprint);
  }

  :global(.flow-dot.sequenced) {
    background: var(--ink);
  }

  .demo-controls {
    max-width: 68rem;
    margin: var(--space-xl) auto 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xl);
  }

  .latency {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .latency input {
    accent-color: var(--overprint);
    width: clamp(8rem, 18vw, 14rem);
  }

  .latency output {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-variant-numeric: tabular-nums;
    min-width: 5ch;
  }

  .race-btn {
    padding: 0.65rem 1.2rem;
    border: 1px solid var(--ink);
    background: var(--bg);
    font-weight: 600;
    cursor: pointer;
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      transform var(--dur-feedback) var(--ease-out-quart);
  }

  .race-btn:hover:enabled {
    background: var(--overprint-faint);
  }

  .race-btn:active:enabled {
    transform: scale(0.97);
  }

  .reset-btn {
    padding: 0.65rem 1.2rem;
    border: 1px solid var(--hairline);
    background: var(--bg);
    color: var(--muted);
    font-weight: 400;
    cursor: pointer;
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      color var(--dur-feedback) var(--ease-out-quart),
      transform var(--dur-feedback) var(--ease-out-quart);
  }

  .reset-btn:hover:enabled {
    background: var(--surface);
    color: var(--ink);
  }

  .reset-btn:active:enabled {
    transform: scale(0.97);
  }

  /* controls boot disabled; initDemo() enables them once the kernels load */
  .gauge-actions button:disabled,
  .counter-actions button:disabled,
  .race-btn:disabled,
  .reset-btn:disabled {
    opacity: 0.45;
    cursor: default;
  }

  .status {
    font-size: var(--text-sm);
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  /* :global — the stamp is re-rendered from JS without Astro's scope attr */
  .status :global(.stamp) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border: 1.5px solid currentColor;
    transform: rotate(-2deg);
  }

  .status :global(.stamp.converged) {
    color: var(--waterline);
  }

  .status :global(.stamp.revising) {
    color: var(--overprint-deep);
  }

  .demo-noscript {
    max-width: 68rem;
    margin: var(--space-lg) auto 0;
    color: var(--overprint-deep);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    .rig {
      grid-template-areas: "a" "seq" "b";
      grid-template-columns: 1fr;
    }

    .op-log {
      max-height: 5.7rem;
    }
  }

  /* three picker cells no longer fit one row on narrow sheets: stack them
     like a printed legend column */
  @media (max-width: 560px) {
    .dds-picker {
      flex-direction: column;
      width: 100%;
    }

    .dds-picker label + label {
      border-inline-start: 0;
      border-block-start: 1px solid var(--ink);
    }
  }

  /* touch input: 44px minimum targets, keyed to pointer, not viewport */
  @media (pointer: coarse) {
    .gauge-actions button {
      inline-size: 2.75rem;
      block-size: 2.75rem;
    }

    .counter-actions button {
      min-inline-size: 2.75rem;
      block-size: 2.75rem;
    }

    .dds-picker label {
      padding-block: 0.8rem;
    }

    .race-btn,
    .reset-btn {
      padding: 0.85rem 1.2rem;
    }
  }
</style>
