---
const gauges = [
  { key: "mill-race", value: 24 },
  { key: "kettle-run", value: 61 },
  { key: "low-ford", value: 42 },
];
const counter = { key: "sandbags-placed", value: 120 };
const gCounter = { key: "inspection-count", value: 18 };
const pn = { key: "earthwork-balance", fill: 74, cut: 30 };
const stockpiles = [
  { key: "spoil-north", value: 18 },
  { key: "borrow-pit-7", value: -6 },
  { key: "wash-fill", value: 12 },
];
const markers = [
  { key: "north-stake", value: "marked" },
  { key: "sluice-tag", value: "marked" },
  { key: "borrow-flag", value: "clear" },
];
const benchmarks = [
  { key: "BM-17", value: "recorded" },
  { key: "BM-22", value: "unrecorded" },
  { key: "BM-31", value: "unrecorded" },
];
const retiredMarkers = [
  { key: "stake-3", value: "active" },
  { key: "gate-pin", value: "unplaced" },
  { key: "silt-flag", value: "retired" },
];
const claimSlots = [
  { key: "north-levee", holder: null },
  { key: "spillway-gate", holder: null },
  { key: "pump-house", holder: "Survey" },
];
const registerSlots = [
  { key: "north-bench", atomic: "Survey", lww: "Survey" },
  { key: "gate-setpoint", atomic: "—", lww: "—" },
  { key: "pump-mode", atomic: "—", lww: "—" },
];
const pactSlots = [
  { key: "datum-grid", accepted: "Survey datum" },
  { key: "gate-policy", accepted: "—" },
  { key: "inspection-window", accepted: "—" },
];
const taskSlots = [
  { key: "sluice-inspection" },
  { key: "pump-watch" },
  { key: "crest-walk" },
];
const clients = [
  { id: "a", name: "Client A" },
  { id: "b", name: "Client B" },
  { id: "c", name: "Client C" },
];
const counterSteps = [-5, -1, 1, 5];
const gCounterSteps = [1, 3, 7];
const pnCutSteps = [-6, -2];
const pnFillSteps = [2, 6];

// ── instance configuration ────────────────────────────────────────────────
// The demo hosts every kernel on one shared sequencer; `views` selects which
// structures this instance offers in its picker. The homepage runs a focused
// SharedMap proof (`views={["map"]}`); each /structures/* page scopes the
// picker to its own family. All kernels still boot on every instance — the
// picker just decides which are reachable, matching DDSes sharing a container.
const ALL_VIEWS = [
  "map", "counter", "gcounter", "pn", "ormap", "orset", "gset",
  "twopset", "claims", "registers", "ordered", "tasks", "pact",
] as const;

interface Props {
  views?: readonly string[];
  initial?: string;
  showPicker?: boolean;
  otJump?: boolean;
  heading?: string;
}

const {
  views = ALL_VIEWS,
  initial = views[0] ?? "map",
  showPicker = views.length > 1,
  otJump = views.includes("map"),
  heading = "Watch three clients converge",
} = Astro.props;

const show = (value: string) => views.includes(value);

const PICKER_CELLS = [
  { value: "map", label: "Shared map", kind: "DDS" },
  { value: "counter", label: "Shared counter", kind: "DDS" },
  { value: "gcounter", label: "G-counter", kind: "CRDT" },
  { value: "pn", label: "PN counter", kind: "CRDT" },
  { value: "ormap", label: "OR-map", kind: "CRDT" },
  { value: "orset", label: "OR-set", kind: "CRDT" },
  { value: "gset", label: "G-set", kind: "CRDT" },
  { value: "twopset", label: "2P-set", kind: "CRDT" },
  { value: "claims", label: "Claims", kind: "DDS" },
  { value: "registers", label: "Registers", kind: "DDS" },
  { value: "ordered", label: "Ordered collection", kind: "DDS" },
  { value: "tasks", label: "TaskManager", kind: "DDS" },
  { value: "pact", label: "Pact map", kind: "DDS" },
].filter((cell) => show(cell.value));
---

<section id="demo" class="demo" aria-labelledby="demo-title">
  <div class="demo-head">
    <h2 id="demo-title">{heading}</h2>
    <slot name="intro">
      <p>
        On a photorevised survey sheet, magenta marks updates not yet
        field-checked. This demo borrows that color code: pending edits are drawn
        in <strong class="k-pending">magenta</strong> and sequenced state in
        <strong class="k-seq">ink</strong>. All three clients run watershed’s real
        Gleam code in one ordered stream — map/G-counter/PN/OR-map/OR-set/G-set/2P-set/claims/register
        kernels, TaskManager, plus the runtime counter channel.
      </p>
      <p class="demo-hint">
        Nudge a gauge, race a concurrent write, stretch the link latency — the
        replicas always converge, each structure by its own rule.
      </p>
      <p class="demo-hint">
        These structures converge by merge rules. For the other family —
        operational transform over a shared JSON document, where concurrent edits
        are <em>transformed</em> past one another — see the
        <a href="/json-ot">JSON OT demo →</a>
      </p>
    </slot>
    <ol class="demo-legend annot" aria-label="How an edit converges">
      <li><span class="k-pending">1 · local edit</span> prints in magenta</li>
      <li><span class="k-flow">2 · the sequencer</span> stamps it with an SN</li>
      <li><span class="k-seq">3 · every client</span> lands the same ink state</li>
    </ol>
  </div>

  <div class="dds-switch">
    {showPicker && (
      <fieldset class="dds-picker" data-dds-picker>
        <legend class="visually-hidden">Data structure shown in all clients</legend>
        {PICKER_CELLS.map((cell) => (
          <label>
            <input
              type="radio"
              name="dds"
              value={cell.value}
              checked={cell.value === initial}
              data-dds-pick
              disabled
            />
            <span>{cell.label} <b>{cell.kind}</b></span>
          </label>
        ))}
        {otJump && (
          <a class="dds-jump" href="/json-ot" aria-label="Open the JSON operational transform demo on its own page">
            <span>JSON OT <b>OT</b></span>
          </a>
        )}
      </fieldset>
    )}
    <p class="merge-rule" data-merge-rule="map" hidden={initial !== "map"}>
      <strong>Merge rule — last write wins.</strong> Race two writes to the
      same key and the op the sequencer stamps later overwrites the earlier
      one, identically on every replica.
    </p>
    <p class="merge-rule" data-merge-rule="counter" hidden={initial !== "counter"}>
      <strong>Merge rule — increments commute.</strong> Race two increments
      and both apply. The counter converges on the sum; nothing is
      overwritten.
    </p>
    <p class="merge-rule" data-merge-rule="gcounter" hidden={initial !== "gcounter"}>
      <strong>Merge rule — grow-only max per replica.</strong> Each client owns
      one monotonically increasing tally. Race two inspections or deliver a
      delta twice: replicas converge by keeping the maximum count seen for
      each author.
    </p>
    <p class="merge-rule" data-merge-rule="pn" hidden={initial !== "pn"}>
      <strong>Merge rule — deltas join a lattice.</strong> Every update
      travels as a CRDT delta; merging is commutative and idempotent. Race
      it, resend it, deliver it twice — it counts exactly once, and the
      balance converges on fill&nbsp;−&nbsp;cut.
    </p>
    <p class="merge-rule" data-merge-rule="claims" hidden={initial !== "claims"}>
      <strong>Merge rule — first writer wins.</strong> A claim commits only
      if the slot is still unclaimed when the sequencer stamps it (or its
      reference SN matches the holder&rsquo;s exactly). Nothing prints
      optimistically: a filed claim is invisible — even to you — until it
      round-trips as won or lost.
    </p>
    <p class="merge-rule" data-merge-rule="ormap" hidden={initial !== "ormap"}>
      <strong>Merge rule — add-wins, observed-remove.</strong> A strike only
      removes stockpile entries the striker had seen. Race a strike against a
      concurrent delivery and the row survives — with every logged yard.
      Re-opening a struck pile brings its ledger back.
    </p>
    <p class="merge-rule" data-merge-rule="orset" hidden={initial !== "orset"}>
      <strong>Merge rule — add-wins, observed-remove.</strong> Clearing a marker
      removes only the add tags this replica had observed. Race a clear against
      a concurrent re-mark and the marker remains present because the fresh tag
      was unseen by the clear.
    </p>
    <p class="merge-rule" data-merge-rule="gset" hidden={initial !== "gset"}>
      <strong>Merge rule — grow-only union.</strong> Marking a benchmark is a
      permanent fact. Race two marks or deliver one twice: the registry only
      grows, and duplicate deltas are absorbed.
    </p>
    <p class="merge-rule" data-merge-rule="twopset" hidden={initial !== "twopset"}>
      <strong>Merge rule — tombstone wins.</strong> A retired marker can never
      become active again. Race a re-place against a retire: both replicas keep
      the tombstone, and duplicate retire deltas are absorbed.
    </p>
    <p class="merge-rule" data-merge-rule="registers" hidden={initial !== "registers"}>
      <strong>Merge rule — atomic plus retained versions.</strong> A write that
      knew the current atomic sequence wins the linearizable slot. Concurrent
      losers still append a version, so LWW reads can intentionally diverge from
      atomic reads.
    </p>
    <p class="merge-rule" data-merge-rule="ordered" hidden={initial !== "ordered"}>
      <strong>Merge rule — FIFO by sequence.</strong> Adds enter the queue in
      server order. Acquires remove the front item when their op sequences; a
      racing acquire may come back empty because the earlier SN already took it.
    </p>
    <p class="merge-rule" data-merge-rule="tasks" hidden={initial !== "tasks"}>
      <strong>Merge rule — one assignee, FIFO waiters.</strong> Volunteers join
      a per-task queue in sequenced order. The first connected volunteer owns the
      task; abandon promotes the next waiter, and complete clears the queue.
    </p>
    <p class="merge-rule" data-merge-rule="pact" hidden={initial !== "pact"}>
      <strong>Merge rule — quorum acceptance.</strong> A set first prints as
      pending with a frozen signoff list. It becomes accepted only after every
      connected client signs off, or leaves drain the list.
    </p>
  </div>

  <div class="rig" data-demo-rig data-dds={initial} data-views={views.join(",")}>
    {
      clients.map((c) => (
        <article
          class="client"
          data-client={c.id}
          aria-label={`${c.name} replica`}
          style={`grid-area: ${c.id}`}
        >
          <header class="client-head">
            <h3>{c.name}</h3>
            <span
              class="pending-count annot"
              data-pending-count
              data-live={c.id}
            >
              0 pending
            </span>
          </header>
          <table class="gauge-table dds-map">
            <caption class="visually-hidden">
              Shared map replica on {c.name}
            </caption>
            <tbody>
              {gauges.map((g) => (
                <tr data-key={g.key}>
                  <th scope="row">
                    <code>{g.key}</code>
                  </th>
                  <td class="gauge-value" data-value>
                    {g.value}
                  </td>
                  <td class="gauge-actions">
                    <button
                      type="button"
                      data-step="-1"
                      aria-label={`Lower ${g.key} on ${c.name}`}
                      disabled
                    >
                      −
                    </button>
                    <button
                      type="button"
                      data-step="1"
                      aria-label={`Raise ${g.key} on ${c.name}`}
                      disabled
                    >
                      +
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <div
            class="counter-panel dds-counter"
            role="group"
            aria-label={`Shared counter replica on ${c.name}`}
          >
            <code class="counter-key">{counter.key}</code>
            <output class="counter-value" data-counter-value>
              {counter.value}
            </output>
            <span
              class="counter-delta annot"
              data-counter-delta
              aria-label="Pending unsequenced delta"
            ></span>
            <div class="counter-actions">
              {counterSteps.map((step) => (
                <button
                  type="button"
                  data-inc={step}
                  aria-label={`${step > 0 ? "Add" : "Remove"} ${Math.abs(step)} ${Math.abs(step) === 1 ? "sandbag" : "sandbags"} on ${c.name}`}
                  disabled
                >
                  {step > 0 ? `+${step}` : `−${Math.abs(step)}`}
                </button>
              ))}
            </div>
          </div>
          <div
            class="counter-panel dds-pn"
            role="group"
            aria-label={`PN counter replica on ${c.name}`}
          >
            <code class="counter-key">{pn.key} · yd³</code>
            <output class="counter-value" data-pn-value>
              +{pn.fill - pn.cut}
            </output>
            <span
              class="counter-delta annot"
              data-pn-delta
              aria-label="Pending unsequenced delta"
            ></span>
            <dl class="pn-ledger">
              <div>
                <dt class="annot">fill Σ</dt>
                <dd data-pn-fill>{pn.fill}</dd>
              </div>
              <div>
                <dt class="annot">cut Σ</dt>
                <dd data-pn-cut>{pn.cut}</dd>
              </div>
            </dl>
            <div class="counter-actions pn-actions">
              <span class="annot" aria-hidden="true">cut</span>
              {pnCutSteps.map((step) => (
                <button
                  type="button"
                  data-pn-inc={step}
                  aria-label={`Cut ${Math.abs(step)} cubic yards on ${c.name}`}
                  disabled
                >
                  −{Math.abs(step)}
                </button>
              ))}
              {pnFillSteps.map((step) => (
                <button
                  type="button"
                  data-pn-inc={step}
                  aria-label={`Fill ${step} cubic yards on ${c.name}`}
                  disabled
                >
                  +{step}
                </button>
              ))}
              <span class="annot" aria-hidden="true">fill</span>
            </div>
          </div>
          <div
            class="counter-panel dds-gcounter"
            role="group"
            aria-label={`G-counter replica on ${c.name}`}
          >
            <code class="counter-key">{gCounter.key}</code>
            <output class="counter-value" data-gcounter-value>
              {gCounter.value}
            </output>
            <span
              class="counter-delta annot"
              data-gcounter-delta
              aria-label="Pending unsequenced increment"
            ></span>
            <dl class="pn-ledger gcounter-ledger">
              {clients.map((author) => (
                <div>
                  <dt class="annot">{author.id.toUpperCase()} Σ</dt>
                  <dd data-gcounter-author={author.id}>0</dd>
                </div>
              ))}
            </dl>
            <div class="counter-actions">
              {gCounterSteps.map((step) => (
                <button
                  type="button"
                  data-gcounter-inc={step}
                  aria-label={`Add ${step} inspections on ${c.name}`}
                  disabled
                >
                  +{step}
                </button>
              ))}
            </div>
          </div>
          <table class="gauge-table claims-table dds-claims">
            <caption class="visually-hidden">
              Claims replica on {c.name}
            </caption>
            <tbody>
              {claimSlots.map((s) => (
                <tr data-key={s.key}>
                  <th scope="row">
                    <code>{s.key}</code>
                  </th>
                  <td class="claim-holder">
                    <output data-holder>{s.holder ?? "—"}</output>
                    <span class="annot claim-note" data-claim-note></span>
                  </td>
                  <td class="gauge-actions claim-actions">
                    <button
                      type="button"
                      data-claim
                      aria-label={`Claim ${s.key} for ${c.name}`}
                      disabled
                    >
                      Claim
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <table class="gauge-table ormap-table dds-ormap">
            <caption class="visually-hidden">
              OR-map stockpile ledger replica on {c.name}
            </caption>
            <tbody>
              {stockpiles.map((s) => (
                <tr data-key={s.key}>
                  <th scope="row">
                    <code>{s.key}</code>
                  </th>
                  <td class="gauge-value ormap-value">
                    <output data-ormap-value>{s.value}</output>
                    <span class="annot ormap-note" data-ormap-note></span>
                  </td>
                  <td class="gauge-actions ormap-actions">
                    <button
                      type="button"
                      data-ormap-log="2"
                      aria-label={`Log 2 cubic yards into ${s.key} on ${c.name}`}
                      disabled
                    >
                      +2
                    </button>
                    <button
                      type="button"
                      data-ormap-log="6"
                      aria-label={`Log 6 cubic yards into ${s.key} on ${c.name}`}
                      disabled
                    >
                      +6
                    </button>
                    <button
                      type="button"
                      data-ormap-strike
                      aria-label={`Strike ${s.key} on ${c.name}`}
                      disabled
                    >
                      ×
                    </button>
                    <button
                      type="button"
                      data-ormap-reopen
                      aria-label={`Re-open ${s.key} on ${c.name}`}
                      disabled
                    >
                      Re-open
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <table class="gauge-table orset-table dds-orset">
            <caption class="visually-hidden">
              OR-set field marker roster replica on {c.name}
            </caption>
            <tbody>
              {markers.map((m) => (
                <tr data-key={m.key}>
                  <th scope="row">
                    <code>{m.key}</code>
                    <span class="annot orset-note" data-orset-note></span>
                  </th>
                  <td class="gauge-value orset-value">
                    <output data-orset-value>{m.value}</output>
                  </td>
                  <td class="gauge-actions orset-actions">
                    <button
                      type="button"
                      data-orset-add
                      aria-label={`Mark ${m.key} on ${c.name}`}
                      disabled
                    >
                      Mark
                    </button>
                    <button
                      type="button"
                      data-orset-remove
                      aria-label={`Clear ${m.key} on ${c.name}`}
                      disabled
                    >
                      Clear
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <table class="gauge-table gset-table dds-gset">
            <caption class="visually-hidden">
              G-set permanent benchmark registry replica on {c.name}
            </caption>
            <tbody>
              {benchmarks.map((b) => (
                <tr data-key={b.key}>
                  <th scope="row">
                    <code>{b.key}</code>
                    <span class="annot gset-note" data-gset-note></span>
                  </th>
                  <td class="gauge-value gset-value">
                    <output data-gset-value>{b.value}</output>
                  </td>
                  <td class="gauge-actions gset-actions">
                    <button
                      type="button"
                      data-gset-add
                      aria-label={`Record benchmark ${b.key} on ${c.name}`}
                      disabled
                    >
                      Record
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <table class="gauge-table twopset-table dds-twopset">
            <caption class="visually-hidden">
              2P-set retired marker ledger replica on {c.name}
            </caption>
            <tbody>
              {retiredMarkers.map((m) => (
                <tr data-key={m.key}>
                  <th scope="row">
                    <code>{m.key}</code>
                    <span class="annot twopset-note" data-twopset-note></span>
                  </th>
                  <td class="gauge-value twopset-value">
                    <output data-twopset-value>{m.value}</output>
                  </td>
                  <td class="gauge-actions twopset-actions">
                    <button
                      type="button"
                      data-twopset-add
                      aria-label={`Place marker ${m.key} on ${c.name}`}
                      disabled
                    >
                      Place
                    </button>
                    <button
                      type="button"
                      data-twopset-remove
                      aria-label={`Retire marker ${m.key} on ${c.name}`}
                      disabled
                    >
                      Retire
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <table class="gauge-table register-table dds-registers">
            <caption class="visually-hidden">
              Register collection replica on {c.name}
            </caption>
            <thead>
              <tr>
                <th scope="col">register</th>
                <th scope="col">atomic</th>
                <th scope="col">LWW</th>
                <th scope="col">revise</th>
              </tr>
            </thead>
            <tbody>
              {registerSlots.map((r) => (
                <tr data-key={r.key}>
                  <th scope="row">
                    <code>{r.key}</code>
                    <span class="annot register-note" data-register-note></span>
                  </th>
                  <td class="register-value">
                    <output data-register-atomic>{r.atomic}</output>
                  </td>
                  <td class="register-value">
                    <output data-register-lww>{r.lww}</output>
                    <span class="annot register-versions" data-register-versions>
                    </span>
                  </td>
                  <td class="gauge-actions register-actions">
                    <button
                      type="button"
                      data-register-write
                      aria-label={`Revise ${r.key} on ${c.name}`}
                      disabled
                    >
                      Revise
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <table class="gauge-table ordered-table dds-ordered">
            <caption class="visually-hidden">
              Ordered collection replica on {c.name}
            </caption>
            <thead>
              <tr>
                <th scope="col">sheet</th>
                <th scope="col">state</th>
                <th scope="col">op</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <th scope="row">
                  <code>queue</code>
                  <span class="annot ordered-note" data-ordered-note></span>
                </th>
                <td class="ordered-value">
                  <output data-ordered-queue>grade-stakes, pump-check</output>
                </td>
                <td class="gauge-actions ordered-actions">
                  <button type="button" data-ordered-add disabled>Add task</button>
                  <button type="button" data-ordered-acquire disabled>Acquire</button>
                </td>
              </tr>
              <tr>
                <th scope="row">
                  <code>held jobs</code>
                </th>
                <td class="ordered-value">
                  <output data-ordered-jobs>none</output>
                </td>
                <td class="gauge-actions ordered-actions">
                  <button type="button" data-ordered-complete disabled>Complete</button>
                  <button type="button" data-ordered-release disabled>Release</button>
                </td>
              </tr>
            </tbody>
          </table>
          <table class="gauge-table pact-table dds-pact">
            <caption class="visually-hidden">Pact map replica on {c.name}</caption>
            <thead>
              <tr>
                <th scope="col">pact</th>
                <th scope="col">accepted</th>
                <th scope="col">pending</th>
                <th scope="col">op</th>
              </tr>
            </thead>
            <tbody>
              {pactSlots.map((p) => (
                <tr data-key={p.key}>
                  <th scope="row">
                    <code>{p.key}</code>
                    <span class="annot pact-note" data-pact-note></span>
                  </th>
                  <td class="pact-value">
                    <output data-pact-accepted>{p.accepted}</output>
                  </td>
                  <td class="pact-value">
                    <output data-pact-pending>—</output>
                    <span class="annot pact-signoffs" data-pact-signoffs></span>
                  </td>
                  <td class="gauge-actions pact-actions">
                    <button
                      type="button"
                      data-pact-set
                      aria-label={`Propose pact ${p.key} on ${c.name}`}
                      disabled
                    >
                      Propose
                    </button>
                    <button
                      type="button"
                      data-pact-delete
                      aria-label={`Delete pact ${p.key} on ${c.name}`}
                      disabled
                    >
                      Delete
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
          <table class="gauge-table task-table dds-tasks">
            <caption class="visually-hidden">TaskManager replica on {c.name}</caption>
            <thead>
              <tr>
                <th scope="col">task</th>
                <th scope="col">assigned</th>
                <th scope="col">waiters</th>
                <th scope="col">op</th>
              </tr>
            </thead>
            <tbody>
              {taskSlots.map((t) => (
                <tr data-key={t.key}>
                  <th scope="row">
                    <code>{t.key}</code>
