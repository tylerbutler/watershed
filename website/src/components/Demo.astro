      </ol>
    </div>

    <div class="flow-layer" data-flow-layer aria-hidden="true"></div>
  </div>

  <div class="demo-controls">
    <label class="latency">
      <span class="annot">Link latency</span>
      <input
        type="range"
        min="100"
        max="2000"
        step="100"
        value="700"
        data-latency
        title="Simulated network delay — how long an op spends travelling client → sequencer → replicas. This is the demo's physics: it changes ordering and which writes collide."
        disabled
      />
      <output data-latency-out>700 ms</output>
    </label>
    <label class="pace">
      <span class="annot">Animation speed</span>
      <input
        type="range"
        min="0.25"
        max="2"
        step="0.25"
        value="0.5"
        data-pace
        title="Playback multiplier — how fast the whole animation plays on screen. On-screen time = link latency ÷ speed. It only changes how fast you watch; the simulated outcome is identical at any speed."
        disabled
      />
      <output data-pace-out>0.5×</output>
    </label>
    <label class="field-notes-toggle">
      <input
        type="checkbox"
        data-latency-variance
        title="Add random ±50 ms jitter to each hop's link latency, so ops no longer travel in lock-step. Models an unstable network where arrival order can shuffle."
        disabled
      />
      <span class="annot">Jitter ±50&nbsp;ms</span>
    </label>
    <label class="field-notes-toggle">
      <input type="checkbox" data-field-notes disabled />
      <span class="annot">Field notes</span>
    </label>
    <button type="button" class="race-btn" data-race disabled>
      Race a concurrent write
    </button>
    <button
      type="button"
      class="race-btn"
      data-replay
      aria-label="Deliver the most recently sequenced delta a second time to every replica"
      hidden
      disabled
    >
