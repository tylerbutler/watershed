---
// Wavy stratum boundaries, generated once at build time.
function wave(seed: number): string {
  let d = "M0 7";
  for (let x = 0; x <= 1200; x += 75) {
    const y = 7 + Math.sin(x / 90 + seed) * 3.4;
    d += ` L ${x} ${y.toFixed(1)}`;
  }
  return d;
}
const waves = [wave(0.4), wave(2.1), wave(4.4)];
---

<section class="arch" aria-labelledby="arch-title">
  <div class="arch-inner">
    <h2 id="arch-title">One pure core, two runtimes</h2>
    <p class="arch-intro">
      watershed is written once and runs in two places. The shared layer is real
      code, not a diagram convenience: <code>runtime_core</code>,
      <code>channel</code>, <code>wire</code>, and the kernels compile for both
      targets. Erlang and JavaScript keep separate facades, runtimes, and socket
      bindings only where the platform forces them to differ.
    </p>

    <div class="strata" role="img" aria-label="Cross-section of the watershed architecture: target-specific public APIs, runtimes, and transports over a shared pure core of runtime_core, channel, wire, and kernel modules.">
      <div class="target-heads" aria-hidden="true">
        <span class="annot">◍ BEAM target</span>
        <span class="annot">◍ Browser target</span>
      </div>

      <div class="stratum split" data-reveal="settle">
        <div>
          <h3>Facade — <code>watershed</code></h3>
          <p>
            Erlang-only API: blocking <code>connect</code>, OTP subject calls,
            map/counter handles, summaries, and subscriptions.
          </p>
        </div>
        <div>
          <h3>Facade — <code>watershed_js</code></h3>
          <p>
            JavaScript-only API: immediate document handle, <code>on_ready</code>
            callback, promises, and the same DDS verbs.
          </p>
        </div>
      </div>

      <svg class="wave" viewBox="0 0 1200 14" preserveAspectRatio="none" aria-hidden="true">
        <path d={waves[0]}></path>
      </svg>

      <div class="stratum split" data-reveal="settle">
        <div>
          <h3>Runtime — <code>runtime</code></h3>
          <p>
            OTP actor, receiver process, process calls, heartbeat timer, and
            reconnect orchestration.
          </p>
        </div>
        <div>
          <h3>Runtime — <code>runtime_js</code></h3>
          <p>
            Callback-driven shell over a mutable cell; same bootstrap,
            ordering, catch-up, and resubmit discipline.
          </p>
        </div>
      </div>

      <svg class="wave" viewBox="0 0 1200 14" preserveAspectRatio="none" aria-hidden="true">
        <path d={waves[1]}></path>
      </svg>

      <div class="stratum span bedrock" data-reveal="settle">
        <h3>Shared pure core</h3>
        <p>
          <code>runtime_core</code> owns CSN/RSN, ack matching, gap detection,
          detached attach, and resubmit. <code>channel</code> dispatches the
          kernels hosted by the document runtime. <code>wire</code> and
          <code>wire/*</code> encode the same Fluid-compatible payloads on both
          targets.
        </p>
        <p class="core-modules">
          <code>map_kernel</code> · <code>counter_kernel</code> ·
          <code>pn_counter_kernel</code> · <code>or_map_kernel</code> ·
          <code>claims_kernel</code>
        </p>
        <span class="pure-stamp" aria-label="Pure and target-agnostic">Pure · shared</span>
      </div>

      <svg class="wave" viewBox="0 0 1200 14" preserveAspectRatio="none" aria-hidden="true">
        <path d={waves[2]}></path>
      </svg>

      <div class="stratum split" data-reveal="settle">
        <div>
          <h3>Transport — <code>aquamarine</code></h3>
          <p>
            Phoenix channel client over Gun, with Roost decoding; gated to
            Erlang with <code>@target(erlang)</code>.
          </p>
        </div>
        <div>
          <h3>Transport — <code>transport_js</code></h3>
          <p>
            Phoenix.js FFI, socket callbacks, mutable cell helpers, and browser
            Web Crypto dev-token signing.
          </p>
        </div>
      </div>
    </div>

    <p class="arch-note">
      The boundary is enforced by target gates: <code>watershed</code> and
      <code>runtime</code> are <code>@target(erlang)</code>;
      <code>watershed_js</code>, <code>runtime_js</code>, and
      <code>transport_js</code> are <code>@target(javascript)</code>. The
      ungated core underneath is the compiled code running in the browser demo.
    </p>
  </div>
</section>

<style>
  .arch {
    padding: var(--space-section) var(--content-pad);
    border-bottom: 1px solid var(--hairline);
    background: var(--surface);
  }

  .arch-inner {
    max-width: 68rem;
    margin-inline: auto;
  }

  h2 {
    font-size: var(--text-h2);
    font-weight: 620;
    font-stretch: 118%;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .arch-intro {
    margin-top: var(--space-lg);
  }

  .strata {
    margin-top: var(--space-2xl);
    border: 1px solid var(--ink);
    background: var(--bg);
  }

  .target-heads {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
    padding: var(--space-sm) var(--space-lg) 0;
  }

  .target-heads span:last-child {
    text-align: right;
  }

  .stratum {
    padding: var(--space-lg) var(--space-lg);
    position: relative;
  }

  .stratum h3 {
    font-size: var(--text-h3);
    font-weight: 650;
    font-stretch: 115%;
  }

  .stratum p {
    margin-top: var(--space-2xs);
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .stratum code {
    font-size: 0.85em;
    color: var(--ink);
  }

  .stratum-note {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
  }

  .split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
  }

  .split > div:last-child {
    text-align: right;
  }

  .wave {
    display: block;
    width: 100%;
    height: 14px;
  }

  .wave path {
    fill: none;
    stroke: var(--hairline);
    stroke-width: 1;
  }

  /* bedrock hatching: the geological symbol for the layer everything rests on */
  .bedrock {
    background: repeating-linear-gradient(
      -45deg,
      transparent 0 9px,
      var(--hairline-faint) 9px 10px
    );
  }

  .bedrock p {
    color: var(--ink);
  }

  .pure-stamp {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--overprint-deep);
    border: 1.5px solid currentColor;
    padding: 0.2rem 0.55rem;
    transform: rotate(2deg);
    background: var(--bg);
  }

  .arch-note {
    margin-top: var(--space-xl);
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .arch-note code {
    color: var(--ink);
    font-size: 0.9em;
  }

  @media (max-width: 720px) {
    .split {
      grid-template-columns: 1fr;
      gap: var(--space-lg);
    }

    .split > div:last-child {
      text-align: left;
      padding-top: var(--space-md);
      border-top: 1px dashed var(--hairline);
    }

    .target-heads {
      display: none;
    }

    .stratum-note {
      position: static;
      display: block;
      margin-top: var(--space-xs);
    }

    .pure-stamp {
      position: static;
      display: inline-block;
      margin-top: var(--space-sm);
    }
  }
</style>
