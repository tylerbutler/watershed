---
import { structureLinks, categories } from "../data/structures";

const structures = [
  {
    name: "SharedCounter",
    module: "counter_kernel",
    rule: "everyone sends +/− changes instead of overwriting, so simultaneous edits just add up",
    pending: "your change shows next to the confirmed total right away",
    summary: "only one number needs saving, since every change is an add",
  },
  {
    name: "G-Counter",
    module: "lattice_counters/g_counter",
    rule: "each client keeps its own tally; the totals combine safely even if a change arrives twice",
    pending: "your increment overlays the total in magenta until it’s confirmed",
    summary: "each client’s running tally reloads intact",
  },
  {
    name: "PN Counter",
    module: "pn_counter_kernel",
    rule: "keeps separate up and down tallies, so it can move both ways and still shrug off duplicates",
    pending: "adds and subtractions can be re-sent without being counted twice",
    summary: "per-client tallies survive reconnect and repeated delivery",
  },
  {
    name: "G-Set",
    module: "g_set_kernel",
    rule: "an add-only set; once something is in, it stays, and merging is a plain union",
    pending: "your addition shows in magenta until it’s confirmed",
    summary: "the confirmed set reloads as a permanent record",
  },
  {
    name: "2P-Set",
    module: "two_p_set_kernel",
    rule: "supports removal, but once an item is removed it can never be added again",
    pending: "adds and removals show in magenta until they’re confirmed",
    summary: "current items and removed ones reload together",
  },
  {
    name: "OR-Set",
    module: "or_set_kernel",
    rule: "add, remove, and add again all work; if an add and a remove race, the add wins",
    pending: "your change overlays the list in magenta until it’s confirmed",
    summary: "current members and their removal history reload intact",
  },
  {
    name: "SharedMap",
    module: "map_kernel",
    rule: "for each key, the most recent write wins, decided by server order",
    pending: "your writes show instantly, then lock in once the server confirms them",
    summary: "entries reload with the exact keys a Fluid app expects",
  },
  {
    name: "OR-Map",
    module: "or_map_kernel",
    rule: "delete a key while someone else edits it, and the edit survives — the write wins",
    pending: "deleted rows stay readable until the delete is confirmed",
    summary: "entries remember their edit history, not just the current value",
  },
  {
    name: "Claims",
    module: "claims_kernel",
    rule: "the first client to claim a slot owns it; every later claim is refused",
    pending: "a claim only shows as yours once it has actually won — never before",
    summary: "who owns what reloads intact",
  },
  {
    name: "Register collection",
    module: "register_collection_kernel",
    rule: "read the first uncontested write, or the most recent one — your choice, per read",
    pending: "writes stay hidden until confirmed, then settle as the winner or a kept version",
    summary: "every competing version is kept, so either read rule still works later",
  },
  {
    name: "Ordered collection",
    module: "ordered_collection_kernel",
    rule: "items come out in the order the server received them; first to grab one holds it",
    pending: "queue changes stay hidden until the server confirms them",
    summary: "the queue and who holds what reload intact",
  },
  {
    name: "Pact map",
    module: "pact_map_kernel",
    rule: "a value takes effect only once every required client has signed off",
    pending: "a pending proposal blocks competing ones until it’s accepted or dropped",
    summary: "accepted values and pending sign-offs save and restore together",
  },
];

// One representative sheet per family — the homepage teases the breadth without
// enumerating all twelve. The full catalog lives on the /structures/* pages.
const featuredNames = ["SharedMap", "SharedCounter", "OR-Set", "Claims"];
const featured = featuredNames.map(
  (name) => structures.find((dds) => dds.name === name)!,
);

const flow = [
  {
    step: "1",
    title: "Submit",
    detail:
      "A client makes a change and updates just its own local copy for now.",
  },
  {
    step: "2",
    title: "Sequence",
    detail:
      "A server like levee puts everyone’s changes in one order and sends that order to every client.",
  },
  {
    step: "3",
    title: "Confirm / apply",
    detail:
      "The client that made the change locks it in; everyone else applies it through the exact same code.",
  },
  {
    step: "4",
    title: "Summarize",
    detail:
      "A saved snapshot lets any client reload the current state — the same path used after a reconnect.",
  },
];
---

<section class="dds-field" aria-labelledby="dds-field-title">
  <div class="dds-inner">
    <div class="dds-copy">
      <h2 id="dds-field-title">One ordered stream, one clear rule per structure</h2>
      <p>
        watershed doesn’t paper over conflicts with one catch-all merge. Each
        structure states a small, clear rule: what can show up instantly, what
        has to wait for the server to confirm it, and what gets saved so a client
        can reload later.
      </p>
      <p class="dds-atlas-note">
        Only a few of watershed’s structures are shown here. The rest — grouped
        by family — live in the field atlas, our full catalog, each with its own
        live demo.
      </p>
      <nav class="family-nav" aria-label="Data structures in depth">
        <span class="annot">Zoom in by family</span>
        {categories.map((c) => (
          <a href={`/structures/${c.slug}`}>{c.name}</a>
        ))}
        <a class="family-nav-models" href="/models">DDS vs CRDT vs OT →</a>
      </nav>
    </div>

    <div class="sheet-stack" aria-label="Featured DDS kernels">
      {
        featured.map((dds) => (
          <article class="field-sheet" data-reveal="rise">
            <header>
              <div>
                <h3>{dds.name}</h3>
              </div>
              <code>{dds.module}</code>
            </header>
            <dl>
              <div>
                <dt>Merge rule</dt>
                <dd>{dds.rule}</dd>
              </div>
              <div>
                <dt>Before it’s confirmed</dt>
                <dd>{dds.pending}</dd>
              </div>
              <div>
                <dt>What gets saved</dt>
                <dd>{dds.summary}</dd>
              </div>
            </dl>
            <a
              class="field-detail annot"
              href={`/structures/${structureLinks[dds.name].slug}#${structureLinks[dds.name].id}`}
            >
              Read in depth →
            </a>
          </article>
        ))
      }
    </div>
  </div>
</section>

<section class="dds-flow" aria-labelledby="dds-flow-title">
  <div class="flow-inner">
    <h2 id="dds-flow-title">The same channel carries every structure</h2>
    <p>
      Every structure above rides the same ordered stream of changes — the very
      one the live SharedMap demo runs on. Open any family to switch which
      structure is on screen; they all stay hosted together, just like structures
      sharing a single Fluid document.
    </p>

    <ol class="flow-steps">
      {
        flow.map((item) => (
          <li data-reveal="settle">
            <span class="flow-step annot">SN {item.step}</span>
            <div class="flow-step-body">
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .dds-field,
  .dds-flow {
    padding: var(--space-section) var(--content-pad);
    border-bottom: 1px solid var(--hairline);
  }

  .dds-field {
    background:
      linear-gradient(var(--hairline-faint) 1px, transparent 1px),
      linear-gradient(90deg, var(--hairline-faint) 1px, transparent 1px),
      var(--surface);
    background-size: 3.5rem 3.5rem;
  }

  .dds-inner,
  .flow-inner {
    max-width: 68rem;
    margin-inline: auto;
  }

  .dds-inner {
    display: grid;
    grid-template-columns: minmax(15rem, 0.8fr) minmax(0, 1.5fr);
    gap: clamp(var(--space-xl), 6vw, 6rem);
    align-items: start;
  }

  .dds-copy {
    position: sticky;
    top: clamp(var(--space-xl), 12vh, 8rem);
  }

  .dds-atlas-note {
    color: var(--muted);
    font-size: var(--text-sm);
  }

  h2 {
    font-size: var(--text-h2);
    font-weight: 620;
    font-stretch: 118%;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .dds-copy p,
  .flow-inner > p {
    margin-top: var(--space-lg);
  }

  .family-nav {
    margin-top: var(--space-xl);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-xs);
  }

  .family-nav .annot {
    margin-bottom: var(--space-2xs);
  }

  .family-nav a {
    font-weight: 500;
    color: var(--waterline);
    text-decoration: none;
    border-bottom: 1px solid var(--waterline-faint);
  }

  .family-nav a:hover {
    color: var(--overprint-deep);
    border-bottom-color: var(--overprint-deep);
  }

  .family-nav-models {
    margin-top: var(--space-2xs);
    color: var(--overprint-deep) !important;
    border-bottom-color: var(--overprint-faint) !important;
  }

  .sheet-stack {
    display: grid;
    gap: var(--space-md);
  }

  .field-sheet {
    position: relative;
    background: var(--bg);
    border: 1px solid var(--ink);
    padding: var(--space-lg);
  }

  .field-sheet:nth-child(even) {
    margin-left: clamp(0rem, 2vw, 1.35rem);
  }

  .field-sheet::after {
    content: "";
    position: absolute;
    inset: var(--space-sm);
    border: 1px dashed var(--hairline);
    pointer-events: none;
  }

  .field-sheet header {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: space-between;
    gap: var(--space-lg);
    align-items: start;
  }

  h3 {
    font-size: var(--text-h3);
    font-weight: 650;
    font-stretch: 115%;
    line-height: 1.15;
  }

  .field-sheet header code {
    color: var(--overprint-deep);
    font-size: 0.78rem;
    white-space: nowrap;
  }

  .field-sheet dl {
    position: relative;
    z-index: 1;
    margin: var(--space-lg) 0 0;
    display: grid;
    gap: var(--space-sm);
  }

  .field-sheet dl div {
    display: grid;
    grid-template-columns: 8.5rem minmax(0, 1fr);
    gap: var(--space-md);
    padding-top: var(--space-sm);
    border-top: 1px solid var(--hairline);
  }

  .field-sheet dt {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .field-sheet dd {
    margin: 0;
    color: var(--ink);
    font-size: var(--text-sm);
    text-wrap: pretty;
  }

  .field-detail {
    position: relative;
    z-index: 1;
    display: inline-block;
    margin-top: var(--space-lg);
    color: var(--waterline);
    text-decoration: none;
  }

  .field-detail:hover {
    color: var(--overprint-deep);
  }

  .flow-inner {
    display: grid;
    grid-template-columns: minmax(0, 0.75fr) minmax(0, 1.25fr);
    gap: clamp(var(--space-xl), 6vw, 6rem);
    align-items: start;
  }

  .flow-inner > p {
    grid-column: 1;
  }

  .flow-steps {
    grid-column: 2;
    grid-row: 1 / span 2;
    list-style: none;
    margin: 0;
    padding: 0;
    border: 1px solid var(--ink);
    background: var(--bg);
  }

  .flow-steps li {
    display: grid;
    grid-template-columns: 5rem minmax(0, 1fr);
    column-gap: var(--space-lg);
    padding: var(--space-lg);
  }

  .flow-steps li + li {
    border-top: 1px solid var(--hairline);
  }

  .flow-step {
    color: var(--overprint-deep);
  }

  .flow-steps p {
    margin-top: var(--space-xs);
    color: var(--muted);
    font-size: var(--text-sm);
  }

  @media (max-width: 860px) {
    .dds-inner,
    .flow-inner {
      grid-template-columns: 1fr;
    }

    .flow-inner > p,
    .flow-steps {
      grid-column: auto;
      grid-row: auto;
    }

    .field-sheet:nth-child(even) {
      margin-left: 0;
    }
  }

  @media (max-width: 560px) {
    .field-sheet header,
    .field-sheet dl div,
    .flow-steps li {
      grid-template-columns: 1fr;
    }

    .field-sheet header {
      display: grid;
      gap: var(--space-sm);
    }
  }
</style>
