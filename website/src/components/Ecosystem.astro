---
const flows = [
  {
    label: "BEAM client",
    source: "watershed",
    sourceHref: "https://github.com/tylerbutler/watershed",
    verb: "opens Phoenix channels with",
    path: [
      {
        name: "aquamarine",
        href: "https://aquamarine.tylerbutler.com",
      },
      {
        name: "roost",
        href: "https://github.com/tylerbutler/roost",
      },
    ],
    target: "levee",
    targetHref: "https://github.com/tylerbutler/levee",
    note: "OTP runtime, Gun transport, Roost Phoenix V2 frame codec.",
  },
  {
    label: "Browser client",
    source: "watershed_js",
    sourceHref: "https://github.com/tylerbutler/watershed",
    verb: "opens Phoenix channels with",
    path: [{ name: "Phoenix.js", href: "https://hexdocs.pm/phoenix/js/" }],
    target: "levee",
    targetHref: "https://github.com/tylerbutler/levee",
    note: "Gleam JavaScript runtime over transport_js and the browser Web Crypto API.",
  },
  {
    label: "Protocol layer",
    source: "watershed core",
    sourceHref: "https://github.com/tylerbutler/watershed",
    verb: "encodes Fluid messages through",
    path: [
      {
        name: "spillway",
        href: "https://spillway.tylerbutler.com",
      },
    ],
    target: "levee",
    targetHref: "https://github.com/tylerbutler/levee",
    note: "Shared operation, session, sequencing, and summary types.",
  },
  {
    label: "Server side",
    source: "levee",
    sourceHref: "https://github.com/tylerbutler/levee",
    verb: "hosts rooms and broadcasts through",
    path: [
      {
        name: "beryl",
        href: "https://beryl.tylerbutler.com",
      },
      {
        name: "dewdrop",
        href: "https://dewdrop.tylerbutler.com",
      },
    ],
    target: "clients",
    targetHref: "https://github.com/tylerbutler/watershed",
    note: "Channel runtime plus Fluid event adapters on the service side.",
  },
];
---

<footer class="eco" aria-labelledby="eco-title">
  <div class="eco-inner">
    <h2 id="eco-title">The water system</h2>
    <p>
      watershed is one basin in a connected system. The important line is not
      the package list; it is who speaks to whom, and where each target swaps
      transport without changing the shared DDS core.
    </p>
    <ol class="flow-list" aria-label="Package relationships">
      {
        flows.map((flow) => (
          <li class="flow-row">
            <span class="flow-label annot">{flow.label}</span>
            <div class="flow-line">
              <a href={flow.sourceHref}>
                <code>{flow.source}</code>
              </a>
              <span>{flow.verb}</span>
              <span class="flow-path">
                {flow.path.map((pkg, index) => (
                  <>
                    <a href={pkg.href}>
                      <code>{pkg.name}</code>
                    </a>
                    {index < flow.path.length - 1 && (
                      <span aria-hidden="true">→</span>
                    )}
                  </>
                ))}
              </span>
              <span aria-hidden="true">→</span>
              <a href={flow.targetHref}>
                <code>{flow.target}</code>
              </a>
            </div>
            <p>{flow.note}</p>
          </li>
        ))
      }
    </ol>
    <div class="eco-close">
      <a class="cta-primary" href="https://github.com/tylerbutler/watershed">
        Read the source
      </a>
      <span class="annot">MIT · built by Tyler Butler</span>
    </div>
  </div>
</footer>

<style>
  .eco {
    padding: var(--space-section) var(--content-pad)
      clamp(3rem, 6vw, 5rem);
  }

  .eco-inner {
    max-width: 68rem;
    margin-inline: auto;
  }

  h2 {
    font-size: var(--text-h2);
    font-weight: 620;
    font-stretch: 118%;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .eco > .eco-inner > p {
    margin-top: var(--space-lg);
  }

  .flow-list {
    list-style: none;
    margin: var(--space-2xl) 0 0;
    padding: 0;
    border-top: 1px solid var(--ink);
  }

  .flow-row {
    display: grid;
    grid-template-columns: minmax(9rem, 0.34fr) 1fr;
    gap: var(--space-md) var(--space-xl);
    padding: var(--space-lg) 0;
    border-top: 1px solid var(--hairline);
  }

  .flow-row:first-child {
    border-top: 0;
  }

  .flow-row:last-child {
    border-bottom: 1px solid var(--ink);
  }

  .flow-label {
    color: var(--overprint-deep);
    padding-top: 0.08rem;
  }

  .flow-line {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-xs) var(--space-sm);
    max-width: 54rem;
  }

  .flow-line code {
    font-size: 1.0625rem;
  }

  .flow-path {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: var(--space-xs);
    color: var(--muted);
  }

  .flow-row p {
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .flow-row p {
    grid-column: 2;
    margin-top: calc(-1 * var(--space-xs));
  }

  .eco-close {
    margin-top: var(--space-2xl);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-lg);
  }

  .cta-primary {
    display: inline-block;
    padding: 0.8rem 1.6rem;
    background: var(--overprint);
    color: oklch(100% 0 0);
    text-decoration: none;
    font-weight: 600;
    font-stretch: 110%;
    transition: background var(--dur-feedback) var(--ease-out-quart);
  }

  .cta-primary:hover {
    background: var(--overprint-deep);
    color: oklch(100% 0 0);
  }

  @media (max-width: 760px) {
    .flow-row {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }

    .flow-row p {
      grid-column: auto;
      margin-top: 0;
    }
  }
</style>
