---
const clients = [
  { id: "a", name: "Client A" },
  { id: "b", name: "Client B" },
  { id: "c", name: "Client C" },
];
---

<section id="jot-demo" class="demo" aria-labelledby="jot-demo-title">
  <div class="demo-head" data-reveal="rise">
    <h2 id="jot-demo-title">Operational transform, live</h2>
    <p>
      All three clients edit one shared JSON document through watershed’s real
      <code>json_ot_kernel</code> — a port of the ottypes <code>json0</code>
      algebra with the single-op-in-flight client protocol, compiled to
      JavaScript and running in your browser. Optimistic edits are drawn in
      <strong class="k-pending">magenta</strong>; server-sequenced state in
      <strong class="k-seq">ink</strong>.
    </p>
    <p class="demo-hint">
      Nudge the <code>gauge.stage</code> reading or flip its trend, rename the
      site, add or remove a surveyor, reorder the crew, stretch the link latency,
      then race two inserts at the same index. Ops address any depth — the gauge
      lives in a nested object, so a bump targets the path
      <code>.gauge.stage</code>. Numbers add commutatively; a rename is
      last-writer-by-sequencing; but the crew list is where OT earns its keep —
      concurrent inserts have their indices <em>transformed</em> so every replica
      converges to the same array, positions and all.
    </p>
  </div>

  <div class="rig" data-jot-rig>
    {
      clients.map((c) => (
        <article
          class="client"
          data-client={c.id}
          aria-label={`${c.name} replica`}
          style={`grid-area: ${c.id}`}
        >
          <header class="client-head">
            <h3>{c.name}</h3>
            <span class="pending-count annot" data-pending-count>
              0 pending
            </span>
          </header>

          <div class="doc" role="group" aria-label={`${c.name} JSON document`}>
            <span class="jp brace">{"{"}</span>

            <div class="jrow crew-row" data-field="crew" data-node="crew">
              <span class="jkey">"crew"</span><span class="jp colon">: </span
              ><span class="jp bracket">[</span>
              <ul class="crew" data-crew aria-label={`crew array on ${c.name}`} />
              <span class="jp bracket">]</span><span class="jp comma">,</span>
              <button type="button" class="node-action" data-crew-add disabled aria-label={`Add a surveyor to crew on ${c.name}`}>
                + surveyor
              </button>
            </div>

            <div class="jrow jrow-open" data-node="gauge">
              <span class="jkey">"gauge"</span><span class="jp colon">: </span
              ><span class="jp brace">{"{"}</span>
            </div>

            <div class="jnest">
              <div class="jrow" data-field="gauge.stage" data-node="gauge.stage">
                <span class="jkey">"stage"</span><span class="jp colon">: </span
                ><span class="field-value num" data-value>24</span
                ><span class="jp comma">,</span>
                <span class="node-action-group">
                  <button type="button" class="node-action" data-stage-dec disabled aria-label={`Lower stage on ${c.name}`}>
                    −
                  </button>
                  <button type="button" class="node-action" data-stage-inc disabled aria-label={`Raise stage on ${c.name}`}>
                    +
                  </button>
                </span>
              </div>

              <div class="jrow" data-field="gauge.trend" data-node="gauge.trend">
                <span class="jkey">"trend"</span><span class="jp colon">: </span
                ><span class="jstr"><span class="jp quote">"</span
                  ><span class="field-value" data-value>steady</span
                  ><span class="jp quote">"</span></span>
                <button type="button" class="node-action" data-trend-cycle disabled aria-label={`Cycle the gauge trend on ${c.name}`}>
                  cycle
                </button>
              </div>
            </div>

            <div class="jrow jrow-close" data-node="gauge">
              <span class="jp brace">{"}"}</span><span class="jp comma">,</span>
            </div>

            <div class="jrow" data-field="site" data-node="site">
              <span class="jkey">"site"</span><span class="jp colon">: </span
              ><span class="jstr"><span class="jp quote">"</span
                ><span class="field-value" data-value>Mill Race</span
                ><span class="jp quote">"</span></span>
              <button type="button" class="node-action" data-site-cycle disabled aria-label={`Rename the site on ${c.name}`}>
                rename
              </button>
            </div>

            <span class="jp brace">{"}"}</span>
          </div>
        </article>
      ))
    }

    <div class="channel" style="grid-area: seq">
      <div class="seq-node" data-seq-node>
        <span class="annot">Sequencer</span>
        <output class="seq-counter" data-seq-counter aria-label="Latest sequence number">
          SN&nbsp;0
        </output>
      </div>
      <ol
        class="op-log"
        data-op-log
        aria-live="polite"
        aria-label="Sequenced operations, newest first"
      >
      </ol>
    </div>

    <div class="flow-layer" data-flow-layer aria-hidden="true"></div>
  </div>

  <div class="demo-controls" data-reveal="rise">
    <label class="latency">
      <span class="annot">Link latency</span>
      <input
        type="range"
        min="100"
        max="2000"
        step="100"
        value="700"
        data-jot-latency
        disabled
      />
      <output data-jot-latency-out>700 ms</output>
    </label>
    <label class="pace">
      <span class="annot">Animation speed</span>
      <input
        type="range"
        min="0.25"
        max="2"
        step="0.25"
        value="0.5"
        data-jot-pace
        title="Playback multiplier — how fast the whole animation plays on screen. On-screen time = link latency ÷ speed. It only changes how fast you watch; the simulated outcome is identical at any speed."
        disabled
      />
      <output data-jot-pace-out>0.5×</output>
    </label>
    <label class="field-notes-toggle">
      <input
        type="checkbox"
        data-jot-latency-variance
        title="Add random ±50 ms jitter to each hop's link latency, so ops no longer travel in lock-step. Models an unstable network where arrival order can shuffle."
        disabled
      />
      <span class="annot">Jitter ±50&nbsp;ms</span>
    </label>
    <button type="button" class="race-btn" data-jot-race disabled>
      Race two inserts at index 0
    </button>
    <button
      type="button"
      class="reset-btn"
      data-jot-reset
      aria-label="Reset the document to its surveyed baseline"
      disabled
    >
      Reset survey
    </button>
    <p class="status" data-jot-status role="status">
      <span class="stamp converged">Converged</span>
      replicas identical · nothing pending
    </p>
  </div>

  <p class="controls-hint">
    <strong>Link latency</strong> is the simulated network delay — the demo's
    physics. <strong>Animation speed</strong> just scales how fast that plays
    on screen (on-screen time = latency ÷ speed). <strong>Jitter</strong> adds
    random ±50&nbsp;ms per hop, so ops stop travelling in lock-step and their
    arrival order can shuffle. Only latency and jitter change the outcome —
    animation speed only changes how fast you watch.
  </p>

  <noscript>
    <p class="demo-noscript">
      The live demo needs JavaScript — it runs watershed’s actual
      <code>json_ot_kernel</code> and the <code>json_ot</code> transform algebra
      as compiled JavaScript modules in your browser. The rest of the page works
      fine without it.
    </p>
  </noscript>

  <p class="demo-noscript" data-jot-fallback hidden>
    The live demo couldn’t start — it runs watershed’s JSON-OT kernel as compiled
    JavaScript, and this browser didn’t load it. The rest of the page works fine
    without it.
  </p>
</section>

<script>
  try {
    const { initJsonOtDemo } = await import("../scripts/json-ot-demo.ts");
    initJsonOtDemo();
  } catch (error) {
    console.error("watershed json-ot demo failed to start", error);
    const note = document.querySelector("[data-jot-fallback]");
    if (note instanceof HTMLElement) note.hidden = false;
  }
</script>

<style>
  .demo {
    padding: var(--space-section) var(--content-pad);
    border-bottom: 1px solid var(--hairline);
  }

  .demo-head {
    max-width: 68rem;
    margin-inline: auto;
  }

  h2 {
    font-size: var(--text-h2);
    font-weight: 620;
    font-stretch: 118%;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .demo-head p {
    margin-top: var(--space-lg);
  }

  .demo-hint {
    color: var(--ink);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .k-pending {
    color: var(--overprint-deep);
  }

  .k-seq {
    color: var(--ink);
  }

  .rig {
    position: relative;
    max-width: 68rem;
    margin: var(--space-xl) auto 0;
    display: grid;
    grid-template-areas:
      "a seq b"
      "c c   c";
    grid-template-columns: 1fr minmax(11rem, 0.7fr) 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .rig .client[data-client="c"] {
    justify-self: center;
    width: min(100%, 22rem);
  }

  .client {
    border: 1px solid var(--ink);
    background: var(--bg);
    display: flex;
    flex-direction: column;
  }

  .client-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: var(--space-sm) var(--space-md);
    border-bottom: 1px solid var(--hairline);
  }

  .client-head h3 {
    font-size: 1rem;
    font-weight: 650;
    font-stretch: 115%;
    letter-spacing: 0.01em;
    text-transform: uppercase;
  }

  .pending-count {
    color: var(--muted);
    transition: color var(--dur-state) var(--ease-out-quart);
  }

  .pending-count.is-pending {
    color: var(--overprint-deep);
  }

  .doc {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.7;
    padding: var(--space-md) var(--space-md) var(--space-md);
    color: var(--ink);
  }

  .jrow {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.15rem;
    padding: 0.28rem 0.4rem;
    padding-inline-start: 1.6rem;
    border-radius: 2px;
    transition: background var(--dur-state) var(--ease-out-quart);
  }

  .jnest .jrow {
    padding-inline-start: 3rem;
  }

  /* The `{` / `}` lines that bracket the nested object carry no value, so
     tighten their vertical rhythm against the members they wrap. */
  .jrow-open {
    padding-block-end: 0.1rem;
  }

  .jrow-close {
    padding-block-start: 0.1rem;
  }

  .crew-row {
    align-items: baseline;
  }

  /* Node pulse: the exact part of the tree an operation just touched. */
  .jrow.touch-pending {
    background: var(--overprint-faint);
    animation: node-pulse-pending 620ms var(--ease-out-quart);
  }

  .jrow.touch-seq {
    background: color-mix(in oklch, var(--ink) 8%, transparent);
    animation: node-pulse-seq 620ms var(--ease-out-quart);
  }

  @keyframes node-pulse-pending {
    0% { background: var(--overprint); }
    100% { background: var(--overprint-faint); }
  }

  @keyframes node-pulse-seq {
    0% { background: color-mix(in oklch, var(--ink) 22%, transparent); }
    100% { background: color-mix(in oklch, var(--ink) 8%, transparent); }
  }

  @media (prefers-reduced-motion: reduce) {
    .jrow.touch-pending,
    .jrow.touch-seq {
      animation: none;
    }
  }

  .jkey {
    color: var(--waterline);
  }

  .jp {
    color: var(--muted);
  }

  .jstr {
    color: var(--ink);
  }

  .jp.quote {
    color: var(--muted);
  }

  .field-value {
    font-family: var(--font-mono);
    color: var(--ink);
    transition: color var(--dur-state) var(--ease-out-quart);
  }

  .field-value.num {
    font-variant-numeric: tabular-nums;
  }

  .field-value.pending {
    color: var(--overprint-deep);
  }

  .crew {
    list-style: none;
    margin: 0;
    padding: 0 0.15rem;
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2xs);
    min-height: 1.5rem;
  }

  .crew:empty {
    padding: 0;
  }

  .crew :global(.chip) {
    display: inline-flex;
    align-items: baseline;
    gap: 0.1rem;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    line-height: 1.4;
    color: var(--ink);
  }

  .crew :global(.chip .jp) {
    color: var(--muted);
  }

  .crew :global(.chip.pending .chip-name),
  .crew :global(.chip.pending .jp) {
    color: var(--overprint-deep);
  }

  .crew :global(.chip-name) {
    white-space: nowrap;
  }

  .crew :global(.chip-actions) {
    display: inline-flex;
    gap: 0.05rem;
    margin-inline-start: 0.15rem;
    opacity: 0.55;
    transition: opacity var(--dur-feedback) var(--ease-out-quart);
  }

  .crew :global(.chip:hover .chip-actions),
  .crew :global(.chip:focus-within .chip-actions) {
    opacity: 1;
  }

  .crew :global(.chip-actions button) {
    border: 0;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    padding: 0 0.15rem;
    line-height: 1;
    font-size: 0.85rem;
    transition: color var(--dur-feedback) var(--ease-out-quart);
  }

  .crew :global(.chip-actions .chip-del:hover) {
    color: var(--overprint-deep);
  }

  .crew :global(.chip-actions button:hover) {
    color: var(--overprint-deep);
  }

  .node-action-group {
    display: inline-flex;
    gap: 0.15rem;
    margin-inline-start: auto;
  }

  .node-action {
    margin-inline-start: 0.4rem;
    padding: 0.05rem 0.5rem;
    border: 1px solid var(--hairline);
    border-radius: 2px;
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
    cursor: pointer;
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      border-color var(--dur-feedback) var(--ease-out-quart),
      color var(--dur-feedback) var(--ease-out-quart);
  }

  .node-action-group .node-action {
    margin-inline-start: 0;
  }

  .jrow:not(.crew-row) .node-action {
    margin-inline-start: auto;
  }

  .node-action:hover:enabled {
    background: var(--overprint-faint);
    border-color: var(--overprint);
    color: var(--overprint-deep);
  }

  .node-action:active:enabled {
    transform: scale(0.97);
  }

  .node-action:disabled {
    opacity: 0.45;
    cursor: default;
  }

  .channel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding-top: clamp(var(--space-md), 6vw, 4.5rem);
  }

  .seq-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--ink);
    border-radius: 999px;
    background: var(--bg);
  }

  .seq-counter {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-variant-numeric: tabular-nums;
    color: var(--ink);
  }

  .seq-counter.stamped {
    animation: stamp 380ms var(--ease-out-quart);
  }

  @keyframes stamp {
    0% {
      color: var(--overprint);
      transform: scale(1.12);
    }
    100% {
      color: var(--ink);
      transform: none;
    }
  }

  .op-log {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.6;
    color: var(--muted);
    overflow: hidden;
    max-height: 13.5rem;
    mask-image: linear-gradient(black 55%, transparent 96%);
  }

  .op-log :global(li) {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0 0.4rem;
    justify-content: center;
    padding: 0.12rem 0;
  }

  .op-log :global(.op-meta) {
    color: var(--muted);
  }

  .op-log :global(.op-path) {
    color: var(--waterline);
  }

  .op-log :global(.op-kind) {
    color: var(--ink);
  }

  .op-log :global(li:first-child .op-meta) {
    color: var(--ink);
  }

  .flow-layer {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: var(--z-flow);
  }

  :global(.flow-dot) {
    position: absolute;
    top: 0;
    left: 0;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--overprint);
  }

  :global(.flow-dot.sequenced) {
    background: var(--ink);
  }

  .demo-controls {
    max-width: 68rem;
    margin: var(--space-xl) auto 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-xl);
  }

  .latency {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .latency input {
    accent-color: var(--overprint);
    width: clamp(8rem, 18vw, 14rem);
  }

  .latency output {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-variant-numeric: tabular-nums;
    min-width: 5ch;
  }

  .pace {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .pace input {
    accent-color: var(--overprint);
    width: clamp(8rem, 18vw, 14rem);
  }

  .pace output {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-variant-numeric: tabular-nums;
    min-width: 5ch;
  }

  .field-notes-toggle {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    cursor: pointer;
  }

  .field-notes-toggle input {
    accent-color: var(--overprint);
    width: 1.05rem;
    height: 1.05rem;
    cursor: pointer;
  }

  .controls-hint {
    max-width: 68rem;
    margin: var(--space-sm) auto 0;
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  .race-btn {
    padding: 0.65rem 1.2rem;
    border: 1px solid var(--ink);
    background: var(--bg);
    font-weight: 600;
    cursor: pointer;
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      transform var(--dur-feedback) var(--ease-out-quart);
  }

  .race-btn:hover:enabled {
    background: var(--overprint-faint);
  }

  .race-btn:active:enabled {
    transform: scale(0.97);
  }

  .reset-btn {
    padding: 0.65rem 1.2rem;
    border: 1px solid var(--hairline);
    background: var(--bg);
    color: var(--muted);
    font-weight: 400;
    cursor: pointer;
    transition:
      background var(--dur-feedback) var(--ease-out-quart),
      color var(--dur-feedback) var(--ease-out-quart),
      transform var(--dur-feedback) var(--ease-out-quart);
  }

  .reset-btn:hover:enabled {
    background: var(--surface);
    color: var(--ink);
  }

  .reset-btn:active:enabled {
    transform: scale(0.97);
  }

  .race-btn:disabled,
  .reset-btn:disabled {
    opacity: 0.45;
    cursor: default;
  }

  .status {
    font-size: var(--text-sm);
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .status :global(.stamp) {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border: 1.5px solid currentColor;
    transform: rotate(-2deg);
  }

  .status :global(.stamp.converged) {
    color: var(--waterline);
  }

  .status :global(.stamp.revising) {
    color: var(--overprint-deep);
  }

  .demo-noscript {
    max-width: 68rem;
    margin: var(--space-lg) auto 0;
    color: var(--overprint-deep);
  }

  @media (max-width: 1080px) {
    .rig {
      grid-template-areas: "a" "seq" "b" "c";
      grid-template-columns: 1fr;
    }

    .rig .client[data-client="c"] {
      justify-self: stretch;
      width: auto;
    }

    .op-log {
      max-height: 5.7rem;
    }
  }

  @media (pointer: coarse) {
    .node-action {
      min-inline-size: 2.4rem;
      min-block-size: 2.2rem;
    }

    .crew :global(.chip-actions) {
      opacity: 1;
    }

    .crew :global(.chip-actions button) {
      min-inline-size: 1.9rem;
      min-block-size: 1.9rem;
    }

    .race-btn,
    .reset-btn {
      padding: 0.85rem 1.2rem;
    }
  }
</style>
