---
const ledger = [
  {
    id: "B1",
    name: "SharedMap basin",
    detail: "Map kernel, Fluid-compatible ops, summaries, nested handles, BEAM and browser facades",
    status: "implemented",
  },
  {
    id: "B2",
    name: "Runtime channels",
    detail: "Server-sequenced delivery, requestOps catch-up, reconnect, nack policy, heartbeat, resubmit",
    status: "implemented",
  },
  {
    id: "B3",
    name: "CRDT + coordination kernels",
    detail: "Counter, PN counter, G-set, 2P-set, OR-set, OR-map, claims, register collection, ordered collection, and pact map — pure kernels with property and fuzz tests",
    status: "implemented",
  },
  {
    id: "B4",
    name: "Extra runtime channels",
    detail: "OR-map, OR-set, G-set, 2P-set, register collection, and claims promoted to full server-sequenced DDS channels",
    status: "implemented",
  },
  {
    id: "B5",
    name: "SharedDirectory",
    detail: "Recursive SharedMap hierarchy wired as a runtime channel, byte-compatible with Fluid's SharedDirectory",
    status: "implemented",
  },
];
---

<section class="rigor" aria-labelledby="rigor-title">
  <div class="rigor-inner">
    <div class="guarantees">
      <h2 id="rigor-title">What is implemented and proven</h2>
      <p>
        The runtime is tested three ways: against a reference model, against a
        live levee server, and against deliberately nasty orderings of
        operations. The ledger lists the implemented pieces covered by those
        checks.
      </p>
      <dl class="claims">
        <div data-reveal="rise">
          <dt>Property-tested convergence</dt>
          <dd>
            qcheck runs 1,000 randomized rounds each, checking that clients end
            up in the same state no matter who wrote what or when, that
            acknowledgements don’t change the result, and that replaying edits
            lands the same state.
          </dd>
        </div>
        <div data-reveal="rise">
          <dt>Byte-identical wire format</dt>
          <dd>
            Ops match <code>@fluidframework/map</code> exactly —
            <code>{"{"}type, key, value{"}"}</code> down to the byte — verified
            against a corpus generated from the TypeScript kernel itself.
          </dd>
        </div>
        <div data-reveal="rise">
          <dt>Reconnect safety</dt>
          <dd>
            Buffered out-of-order delivery, in-band op requests, and client-id
            remapping on reconnect. Pending edits survive the round trip.
          </dd>
        </div>
      </dl>
    </div>

    <div class="ledger-wrap">
      <table class="ledger">
        <caption class="annot">Implementation ledger</caption>
        <tbody>
          {
            ledger.map((row) => (
              <tr data-reveal="rise">
                <th scope="row">{row.id}</th>
                <td>
                  <span class="ledger-name">{row.name}</span>
                  <span class="ledger-detail">{row.detail}</span>
                </td>
                <td class="ledger-status">{row.status}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>

<style>
  .rigor {
    padding: var(--space-section) var(--content-pad);
    border-bottom: 1px solid var(--hairline);
  }

  .rigor-inner {
    max-width: 68rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: clamp(var(--space-xl), 6vw, 6rem);
    align-items: start;
  }

  h2 {
    font-size: var(--text-h2);
    font-weight: 620;
    font-stretch: 118%;
    letter-spacing: -0.015em;
    line-height: 1.05;
  }

  .guarantees > p {
    margin-top: var(--space-lg);
  }

  .claims {
    margin: var(--space-2xl) 0 0;
  }

  .claims div + div {
    margin-top: var(--space-xl);
  }

  .claims dt {
    font-weight: 650;
    font-stretch: 112%;
    font-size: var(--text-h3);
  }

  .claims dd {
    margin: var(--space-xs) 0 0;
    color: var(--muted);
    max-width: 48ch;
  }

  .claims code {
    font-size: 0.85em;
    color: var(--ink);
  }

  .ledger-wrap {
    overflow-x: auto;
  }

  .ledger {
    width: 100%;
    border-collapse: collapse;
    border: 1px solid var(--ink);
  }

  .ledger caption {
    text-align: left;
    padding-bottom: var(--space-sm);
  }

  .ledger th,
  .ledger td {
    padding: var(--space-md) var(--space-md);
    border-top: 1px solid var(--hairline);
    vertical-align: baseline;
    text-align: left;
  }

  .ledger tr:first-child th,
  .ledger tr:first-child td {
    border-top: none;
  }

  .ledger th {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: var(--text-sm);
    color: var(--muted);
    width: 3.5rem;
  }

  .ledger-name {
    display: block;
    font-weight: 650;
    font-stretch: 112%;
  }

  .ledger-detail {
    display: block;
    font-size: var(--text-sm);
    color: var(--muted);
    margin-top: var(--space-2xs);
    text-wrap: pretty;
  }

  .ledger-status {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    white-space: nowrap;
    width: 1%;
  }

  @media (max-width: 860px) {
    .rigor-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
